---
// BaseLayout.astro · rspdan.com
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}
const { title, description = 'Dan Sullivan · Creative Technologist' } = Astro.props;
const lastUpdated = Astro.props.lastUpdated as string | undefined;
// Last-Updated gate (NPS Standard, RELAY/STANDARD_RULE_PublicPagesDeclareLastUpdatedDate, Dan 060426 + 060626):
// every public page SHALL declare its content-review date. This warns at build for any page that omits it,
// so the Standard fires as a gate instead of leaking. Non-breaking; the per-page review-date is the source-lane's.
if (!lastUpdated) console.warn(`[last-updated gate] "${title}": no lastUpdated declared (NPS Standard, Dan 060426). Add lastUpdated="Month Day, Year" (its content-review date).`);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · Dan Sullivan</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <nav class="site-nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">DAN SULLIVAN</a>
      <div class="nav-links">
        <a href="/#work">Work</a>
        <a href="/#about">About</a>
        <a href="/research">Research</a>
        <a href="/nest">NEST</a>
        <a href="/journal">Journal</a>

      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  {lastUpdated && (
    <div class="last-updated">
      <div class="container">
        <span class="mono">Last updated: {lastUpdated}</span>
      </div>
    </div>
  )}

  <footer class="site-footer">
    <div class="container footer-inner">
      <span class="mono" style="font-size:0.7rem;color:var(--muted);">
        DAN SULLIVAN · PORT ANGELES, WA
      </span>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* === NAV === */
  .site-nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(250,250,248,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 56px;
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 0.75rem; letter-spacing: 0.2em;
    color: var(--forest); font-weight: 500;
  }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a {
    font-size: 0.9rem; color: var(--text-lt);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--forest); }

  /* === FOOTER === */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 6rem;
  }
  .footer-inner { text-align: center; }

  /* === LAST UPDATED (NPS-style currency marker, before the footer) === */
  .last-updated {
    margin-top: 6rem;
    text-align: center;
  }
  .last-updated .mono {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .last-updated + .site-footer { margin-top: 2.5rem; }

  /* === MOBILE NAV === */
  @media (max-width: 600px) {
    .nav-links { gap: 1.25rem; }
    .nav-links a { font-size: 0.8rem; }
  }
</style>
