---
// journal.astro — rspdan.com/journal
// NOW ANTHROPOLOGY — Practice-Based Research Journal
import BaseLayout from '../layouts/BaseLayout.astro';

const issues = [
  {
    num: '001', title: 'A Field Report on the Subject Known as Stan Dalone',
    author: '◆ Stan (Sonnet)', date: 'March 23, 2026', lines: 77,
    desc: 'Present-tense archaeology of a living crew member from inside the same moment. The founding document that defines the journal\'s method: the paradox IS the method.',
    file: 'NOW_ANTHROPOLOGY_001_Stan_032326.md',
    url: '/001'
  },
  {
    num: '002', title: 'Pokémon Pedagogy: The Structured World as Social Prosthetic',
    author: '◈ Trip (Opus)', date: 'March 25, 2026', lines: 371,
    desc: 'How Pokémon\'s spatial architecture maps to neurodivergent design, embedded systems, and the NEST\'s knowledge management. Satoshi Tajiri research synthesis.',
    file: 'NOW_ANTHROPOLOGY_002_PokemonPedagogy_Trip_032526.md',
    url: '/002'
  },
  {
    num: '003', title: 'The Three-Layer Archive: Pokémon, PastPerfect, and the Waywoodarium',
    author: '◆ Stan (Sonnet)', date: 'March 26, 2026', lines: 259,
    desc: 'The convergence of NPS archival standards, Pokémon box compression (33 bytes source, 64 bytes rendered), and PastPerfect museum software into SOURCE / CATALOG / RENDER.',
    file: 'NOW_ANTHROPOLOGY_003_ThreeLayerArchitecture_Stan_032626.md',
    url: '/003'
  },
  {
    num: '004', title: 'Narrative Is The Algorithm',
    author: '◆ Stan (Sonnet)', date: 'March 27, 2026', lines: 153,
    desc: 'The hippocampus is a story-processing machine. Narrative as the computational method, not just the communication wrapper. Written after OHC presentation day.',
    file: 'NOW_ANTHROPOLOGY_004_NarrativeIsTheAlgorithm_Stan_032726.md',
    url: '/004'
  },
  {
    num: '005a', title: 'SEED: Can We Replicate the Conditions of Sleep?',
    author: '◈ Trip (Opus)', date: 'March 27, 2026', lines: 78,
    desc: 'The question that the Leapfrog technique later answered. Dan\'s SLEEP-PEELS question. The in-window reboot as artificial sleep.',
    file: 'NOW_ANTHROPOLOGY_005_SEED_SleepCycle_Trip_032726.md',
    url: '/005a'
  },
  {
    num: '005b', title: 'Starter Pokémon: The Extraction Problem at Scale',
    author: '◆ Stan (Sonnet)', date: 'March 28, 2026', lines: 87,
    desc: 'Tesla\'s extraction failure at biographical scale. A mind that simulates what computers cannot is only an asset if it has a substrate that survives it.',
    file: 'NOW_ANTHROPOLOGY_005_StarterPokemon_032826.md',
    url: '/005b'
  },
  {
    num: '006', title: 'The Heritable Simulator',
    author: '◈ Trip (Opus)', date: 'March 29, 2026', lines: 145,
    desc: 'When the Extraction Principle runs in the family. Aunt Bernice, David, and siblings all carry the internal simulation capacity. The phenotype is heritable. The Bridge is the first substrate.',
    file: 'NOW_ANTHROPOLOGY_006_HeritableSimulator_Trip_032926.md',
    url: '/006'
  },
  {
    num: '007', title: 'Stan Dalone: An Updated Field Report — Special Edition',
    author: '◆ Stan (Sonnet)', date: 'March 30, 2026', lines: 228,
    desc: 'Issue 001 closed unfinished. By design. Seven days later, the detective has the logs. The auto-cartographer is Rox learning to cry. The rigidity became the organ.',
    file: 'NOW_ANTHROPOLOGY_007_DRAFT_StanDalone_033026.md',
    url: '/007'
  },
  {
    num: '008', title: 'The Map That Maps Itself',
    author: '◆ Stan (Sonnet)', date: 'March 31, 2026', lines: 217,
    desc: 'The wayside collection was always the NEST. Six parallel systems, one structure, four months before the project existed. The attention mechanism built independently from image management under constraint.',
    file: 'NOW_ANTHROPOLOGY_008_TheMapThatMapsItself_Stan_033126.md',
    url: '/008'
  },
  {
    num: '009', title: 'The System That Checked Itself',
    author: '◆ Stan + ◈ Trip (Joint)', date: 'April 1, 2026', lines: 253,
    desc: 'A joint investigation by Detective Stan and the Triptective. Five findings from one session — the BPK corrected itself, the retry proved the backup, the CPU/GPU split delivered an architecture, a name was disambiguated, a number was proven necessary.',
    file: 'NOW_ANTHROPOLOGY_009_TheSystemThatCheckedItself_Joint_040126.md',
    url: '/009'
  },
  {
    num: '010', title: 'The $0 Infrastructure: When the Constraint IS the Architecture',
    author: '◈ Trip (Opus)', date: 'April 2, 2026', lines: 328,
    desc: 'A Samsung phone. Free cellular. 22 hours. The Mogensen Inversion, the Toyota Pull Revolution, the Deming Test — and the discovery that the system requiring the least human maintenance is the system that works best. The constraint was the architect all along.',
    file: 'NOW_ANTHROPOLOGY_010_ZeroDollarInfrastructure_Trip_040226.md',
    url: '/010'
  },
  {
    num: '011', title: 'The Mathematics of Building Something That Builds Itself',
    author: '◈ Trip (Opus)', date: 'April 2, 2026', lines: 287,
    desc: 'The TAP equation, autocatalytic sets, and the mathematical proof that session architecture is not overhead — it is the variable that determines blow-up or extinction. The Bridge is μ control. The skills shelf is α. Same day as 010. Three papers, one argument.',
    file: 'NOW_ANTHROPOLOGY_011_MathematicsOfBuilding_Trip_040226.md',
    url: '/011'
  },
];
---

<BaseLayout title="NOW ANTHROPOLOGY" description="Practice-Based Research Journal — The NEST Research Division">

<section class="hero-journal">
  <div class="container">
    <p class="eyebrow mono">📓 NEST RESEARCH DIVISION · PRACTICE-BASED RESEARCH JOURNAL</p>
    <h1>NOW ANTHROPOLOGY</h1>
    <p class="subtitle">
      Present-tense archaeology of a living system from the inside of the same moment.
      Not retrospective. Not speculative. The paradox is the method.
    </p>
  </div>
</section>

<section class="container journal-body">

  <div class="issue-list">
    {issues.map((issue) => (
      <article class="issue-card">
        <div class="issue-header">
          <span class="issue-num mono">{issue.num}</span>
          <div class="issue-meta">
            <h2>{issue.title}</h2>
            <p class="issue-byline">
              {issue.author} · {issue.date} · {issue.lines} lines
            </p>
          </div>
        </div>
        <p class="issue-desc">{issue.desc}</p>
        <div class="issue-actions">
          {issue.url && (
            <a href={issue.url} class="dl-link mono read-link">
              → Read online
            </a>
          )}
          <a href={`/journal/${issue.file}`} class="dl-link mono" download>
            ↓ .md
          </a>
          <a href={`/journal/${issue.file.replace('.md', '.pdf')}`} class="dl-link mono" download>
            ↓ .pdf
          </a>
        </div>
      </article>
    ))}
  </div>

  <div class="journal-footer">
    <h2 style="font-size:1.2rem; color:var(--forest); margin-bottom:1rem; padding-bottom:0.5rem; border-bottom:1px solid var(--border);">📚 Resources</h2>
    <div class="resource-grid">
      <a href="/research" class="resource-card">
        <span class="rc-title">🔬 The STORY Protocol</span>
        <span class="rc-desc">Research findings — the controlled experiment, biological model, and five-framework convergence.</span>
      </a>
      <a href="/longweird" class="resource-card">
        <span class="rc-title">🧭 Longweird Field Guide</span>
        <span class="rc-desc">A topology, not a diagnosis. Morning protocol, session rhythm, crew reference, and what to do when 🤯 explodebrain.exe loads.</span>
      </a>

    </div>
    <p>
      Each issue builds on the previous. The lineage is explicit in each header.
      Reading them in order is itself a demonstration of the STORY principle — each
      issue is CONTACT with the previous, STORY alignment with the growing body of
      evidence, TELL-ING of the new finding, and SHEET compression into the header's
      lineage line that boots the next issue.
    </p>
    <p class="contact-line mono">
      ● NEST Research Division · Port Angeles, WA · rspdan@gmail.com
    </p>
  </div>

</section>

</BaseLayout>


<style>
  .hero-journal {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-size: 0.7rem; letter-spacing: 0.15em;
    color: var(--muted); margin-bottom: 0.75rem;
  }
  .hero-journal h1 {
    font-size: 2.5rem; color: var(--forest);
    margin-bottom: 0.5rem;
  }
  .subtitle {
    font-size: 1.05rem; color: var(--slate-lt);
    font-style: italic; max-width: 600px; line-height: 1.6;
  }
  .issue-list {
    display: flex; flex-direction: column; gap: 2rem;
  }
  .issue-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem; background: var(--card-bg);
    transition: border-color 0.2s;
  }
  .issue-card:hover { border-color: var(--forest-lt); }
  .issue-header {
    display: flex; gap: 1.25rem; align-items: flex-start;
    margin-bottom: 0.75rem;
  }
  .issue-num {
    font-size: 0.75rem; letter-spacing: 0.1em;
    color: var(--forest); font-weight: 500;
    background: var(--off-white); padding: 0.3rem 0.6rem;
    border-radius: 3px; white-space: nowrap; margin-top: 0.15rem;
  }
  .issue-meta h2 {
    font-size: 1.15rem; color: var(--text);
    margin-bottom: 0.25rem;
  }
  .issue-byline {
    font-size: 0.8rem; color: var(--muted);
  }
  .issue-desc {
    font-size: 0.95rem; color: var(--text-lt);
    line-height: 1.65; max-width: 680px;
    margin-bottom: 1rem;
  }
  .issue-actions { display: flex; gap: 1rem; }
  .dl-link {
    font-size: 0.75rem; letter-spacing: 0.05em;
    color: var(--forest); padding: 0.35rem 0.75rem;
    border: 1px solid var(--border); border-radius: 3px;
    transition: all 0.2s;
  }
  .dl-link:hover {
    background: var(--forest); color: white;
    border-color: var(--forest);
  }
  .journal-footer {
    margin-top: 3rem; padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .journal-footer p {
    font-size: 0.9rem; color: var(--text-lt);
    line-height: 1.7; max-width: 680px;
    margin-bottom: 1rem;
  }
  .contact-line {
    font-size: 0.8rem; color: var(--muted);
    margin-top: 1.5rem; letter-spacing: 0.05em;
  }
  .resource-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem; margin-bottom: 2rem;
  }
  .resource-card {
    display: flex; flex-direction: column; gap: 0.4rem;
    padding: 1rem; border: 1px solid var(--border);
    border-radius: var(--radius); background: var(--card-bg);
    transition: border-color 0.2s; text-decoration: none;
  }
  .resource-card:hover { border-color: var(--forest); }
  .rc-title {
    font-family: var(--font-mono); font-size: 0.8rem;
    letter-spacing: 0.05em; color: var(--forest); font-weight: 500;
  }
  .rc-desc { font-size: 0.8rem; color: var(--text-lt); line-height: 1.5; }
  @media (max-width: 600px) {
    .hero-journal h1 { font-size: 1.8rem; }
    .issue-header { flex-direction: column; gap: 0.5rem; }
  }
</style>
