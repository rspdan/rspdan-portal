.na-issue-num { font-size:5rem; line-height:1; color:rgba(255,255,255,0.08); letter-spacing:-0.05em; margin-bottom:-1.5rem; font-weight:700; }
.na-title { font-family:var(--font-head); font-size:clamp(2.5rem,6vw,4.5rem); color:var(--warm-white); letter-spacing:-0.02em; line-height:1.1; margin-bottom:1.25rem; }
