    </div>
  </div>
</section>

<div class="na-lineage">
  <div class="container">
    <span class="mono">LINEAGE: </span>
    <a href="/journal/NOW_ANTHROPOLOGY_003_ThreeLayerArchitecture_Stan_032626.md" class="na-lineage__link mono">003 â€” Three-Layer Archive</a>
    <span class="na-lineage__sep">Â·</span>
    <a href="/007" class="na-lineage__link mono">007 â€” Stan Dalone Special Edition</a>
    <span class="na-lineage__sep">Â·</span>
