.na-end-nav-section{padding:3rem 0 5rem;background:var(--off-white);border-top:1px solid var(--border);}
.na-end-nav{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;max-width:900px;margin:0 auto;}
.na-end-nav__link{display:flex;flex-direction:column;padding:1.25rem 1.5rem;border:1px solid var(--border);border-radius:var(--radius);text-decoration:none;color:var(--text);background:var(--warm-white);transition:all 0.2s;}
.na-end-nav__link:hover:not(.na-end-nav__disabled){border-color:var(--forest);background:var(--forest);color:var(--warm-white);}
.na-end-nav__link:hover:not(.na-end-nav__disabled) .na-end-nav__dir{color:var(--teal);}
.na-end-nav__dir{font-size:0.65rem;letter-spacing:0.15em;color:var(--forest);margin-bottom:0.5rem;}
.na-end-nav__title{font-size:0.95rem;font-weight:500;}
.na-end-nav__all{text-align:center;}
.na-end-nav__next{text-align:right;}
.na-end-nav__next .na-end-nav__dir{text-align:right;}
.na-end-nav__disabled{opacity:0.4;cursor:default;}
@media (max-width:680px){.na-end-nav{grid-template-columns:1fr;}.na-end-nav__next,.na-end-nav__all{text-align:left;}.na-end-nav__next .na-end-nav__dir{text-align:left;}}
</style>
</BaseLayout>
