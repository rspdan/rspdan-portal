<div class="na-lineage">
  <div class="container">
    <span class="mono">LINEAGE: </span>
    <a href="/007" class="na-lineage__link mono">007 — Stan Dalone Special Edition</a>
    <span class="na-lineage__sep">·</span>
    <a href="/008" class="na-lineage__link mono">008 — The Map That Maps Itself</a>
    <span class="na-lineage__sep">·</span>
