<BaseLayout title="Session Log" description="NEST session timeline — crew navigation tool, unlisted">
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&display=swap');
:root {
  --bg:#0c0e14; --card:#13161f; --border:rgba(255,255,255,0.06);
  --muted:#4a5468; --text:#b8bfcc; --head:#e2e8f0;
  --line:rgba(255,255,255,0.08);
  --c-milestone:#c9a84c; --c-crew:#4a9b8e; --c-early:#8b7ab5;
  --c-bridge:#5a8a5e; --c-stn2:#4a7ab5; --c-deep:#8a6b4a;
  --c-research:#6a8a6a; --c-today:#c94c4c; --c-stanshop:#4a8a9b;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'IBM Plex Mono',monospace;}
.shell{max-width:900px;margin:0 auto;padding:3rem 1.5rem 8rem;}
.hdr{border-bottom:1px solid var(--border);padding-bottom:1.5rem;margin-bottom:2rem;}
.eyebrow{font-size:0.52rem;letter-spacing:0.32em;color:var(--muted);text-transform:uppercase;margin-bottom:0.4rem;}
.title{font-size:1.5rem;color:var(--head);font-weight:300;letter-spacing:0.04em;}
.sub{font-size:0.58rem;color:var(--muted);margin-top:0.4rem;letter-spacing:0.1em;line-height:1.6;}
.legend{display:flex;flex-wrap:wrap;gap:0.75rem 1.25rem;margin-bottom:2.5rem;}
.leg{display:flex;align-items:center;gap:0.35rem;font-size:0.5rem;letter-spacing:0.12em;color:var(--muted);text-transform:uppercase;}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.timeline{position:relative;padding-left:2rem;}
.timeline::before{content:'';position:absolute;left:0.25rem;top:0;bottom:0;width:1px;background:var(--line);}
.entry{position:relative;margin-bottom:0.6rem;}
.entry::before{content:'';position:absolute;left:-1.75rem;top:1rem;width:8px;height:8px;border-radius:50%;background:var(--dot-color,var(--muted));box-shadow:0 0 6px var(--dot-color,transparent);}
.inner{background:var(--card);border:1px solid var(--border);border-left:2px solid var(--dot-color,var(--border));padding:0.65rem 0.9rem;border-radius:2px;cursor:pointer;transition:border-color 0.15s;}
.inner:hover{border-color:var(--dot-color);}
.row1{display:flex;align-items:baseline;gap:0.75rem;flex-wrap:wrap;}
.date-label{font-size:0.58rem;letter-spacing:0.18em;color:var(--muted);text-transform:uppercase;min-width:3.5rem;}
.niap{font-size:0.48rem;letter-spacing:0.12em;color:var(--muted);opacity:0.6;}
.count{font-size:0.5rem;letter-spacing:0.1em;color:var(--dot-color,var(--muted));opacity:0.8;}
.who-badge{font-size:0.45rem;letter-spacing:0.08em;color:var(--muted);background:rgba(255,255,255,0.04);padding:0.1rem 0.35rem;border-radius:2px;border:1px solid var(--border);}
.note-text{font-size:0.62rem;color:var(--text);line-height:1.55;margin-top:0.2rem;}
.expand-body{display:none;margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid var(--border);}
.expand-body.open{display:block;}
.section-label{font-size:0.45rem;letter-spacing:0.18em;color:var(--muted);text-transform:uppercase;margin-bottom:0.3rem;}
.s-item{font-size:0.55rem;color:var(--muted);padding:0.08rem 0;}
.s-item::before{content:'· ';}
.docs-grid{display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.3rem;}
.doc-item{display:flex;align-items:center;gap:0.15rem;}
.doc-name{font-size:0.52rem;color:var(--text);letter-spacing:0.03em;padding:0.2rem 0.4rem;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:2px 0 0 2px;}
.doc-btn{font-size:0.48rem;color:var(--dot-color,var(--muted));padding:0.2rem 0.4rem;border:1px solid var(--border);border-left:none;text-decoration:none;transition:all 0.15s;letter-spacing:0.05em;white-space:nowrap;}
.doc-btn:hover{background:var(--dot-color);color:#000;border-color:var(--dot-color);}
.doc-btn.first{border-radius:0;}
.no-docs{font-size:0.5rem;color:var(--muted);opacity:0.5;font-style:italic;}
.type-milestone{--dot-color:var(--c-milestone);}
.type-crew{--dot-color:var(--c-crew);}
.type-early{--dot-color:var(--c-early);}
.type-bridge{--dot-color:var(--c-bridge);}
.type-stn2{--dot-color:var(--c-stn2);}
.type-deep{--dot-color:var(--c-deep);}
.type-research{--dot-color:var(--c-research);}
.type-today{--dot-color:var(--c-today);}
.type-stanshop{--dot-color:var(--c-stanshop);}
.station-pills{display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.3rem;}
.station-pill{font-size:0.45rem;letter-spacing:0.1em;padding:0.1rem 0.4rem;border:1px solid rgba(255,255,255,0.08);border-radius:10px;color:var(--muted);}
</style>

<div class="shell">
  <div class="hdr">
    <div class="eyebrow">&#128204; NEST SESSION TIMELINE — PASS 2</div>
    <h1 class="title">Session Log</h1>
    <div class="sub">
      UNLISTED &#8212; CREW NAVIGATION ONLY<br>
      129 sessions · 29 active days · 0 gaps · Mar 4–Apr 1 2026<br>
      Station from session name · WHO from content only · UNKNOWN is valid<br>
      Click any entry to expand · View opens in tab · ↓ .md downloads file
    </div>
  </div>

  <div class="legend">
    <div class="leg"><div class="dot" style="background:var(--c-milestone)"></div>Milestone</div>
    <div class="leg"><div class="dot" style="background:var(--c-early)"></div>Early</div>
    <div class="leg"><div class="dot" style="background:var(--c-crew)"></div>Crew ops</div>
    <div class="leg"><div class="dot" style="background:var(--c-stanshop)"></div>Stan's Shop era</div>
    <div class="leg"><div class="dot" style="background:var(--c-bridge)"></div>Bridge / fleet</div>
    <div class="leg"><div class="dot" style="background:var(--c-stn2)"></div>STN2 logs</div>
    <div class="leg"><div class="dot" style="background:var(--c-deep)"></div>Deep work</div>
    <div class="leg"><div class="dot" style="background:var(--c-research)"></div>Research</div>
    <div class="leg"><div class="dot" style="background:var(--c-today)"></div>Today</div>
  </div>

  <div class="timeline">
    {sessions.map((s) => (
      <div class={`entry type-${s.type}`} id={`day-${s.date}`}>
        <div class="inner" onclick={`this.querySelector('.expand-body').classList.toggle('open')`}>
          <div class="row1">
            <span class="date-label">{s.label}</span>
            <span class="niap">{s.niap}</span>
            <span class="count">{s.count} session{s.count !== 1 ? 's' : ''}</span>
            <span class="who-badge">{s.who}</span>
          </div>
          {s.stations && s.stations.length > 0 && (
            <div class="station-pills">
              {s.stations.map(st => <span class="station-pill">{st}</span>)}
            </div>
          )}
          <div class="note-text">{s.note}</div>
          <div class="expand-body">
            <div class="section-label">Sessions</div>
            {s.names.map(n => <div class="s-item">{n}</div>)}
            <div class="section-label" style="margin-top:0.6rem;">Documents</div>
            {s.docs.length > 0 ? (
              <div class="docs-grid">
                {s.docs.map(d => (
                  <div class="doc-item">
                    <span class="doc-name">{d.label}</span>
                    <a href={`/${d.dir ?? 'log'}/${d.file}`} class="doc-btn first" target="_blank">→ View</a>
                    <a href={`/${d.dir ?? 'log'}/${d.file}`} class="doc-btn" download={d.file}>↓ .md</a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="no-docs">No documents exported for this day yet</div>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
</BaseLayout>
