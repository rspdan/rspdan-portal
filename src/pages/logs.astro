// COMPUTED — never hardcode these again
const totalSessions = sessions.reduce((sum, s) => sum + s.count, 0);
const activeDays = sessions.length;
const firstLabel = sessions[0].label;
const lastLabel = sessions[sessions.length - 1].label;
// Gap count: dates in sessions vs full date span from first to last
const msPerDay = 86400000;
const firstDate = new Date(sessions[0].date).getTime();
const lastDate = new Date(sessions[sessions.length - 1].date).getTime();
const spanDays = Math.round((lastDate - firstDate) / msPerDay) + 1;
const totalGaps = spanDays - activeDays;
