---
<BaseLayout title="Session Log" description="NEST session timeline — crew navigation tool, unlisted">
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&display=swap');
:root {
  --bg:     #0c0e14;
  --card:   #13161f;
  --border: rgba(255,255,255,0.06);
  --muted:  #4a5468;
  --text:   #b8bfcc;
  --head:   #e2e8f0;
  --line:   rgba(255,255,255,0.08);
  --c-milestone: #c9a84c;
  --c-crew:      #4a9b8e;
  --c-early:     #8b7ab5;
  --c-bridge:    #5a8a5e;
  --c-stn2:      #4a7ab5;
  --c-deep:      #8a6b4a;
  --c-research:  #6a8a6a;
  --c-today:     #c94c4c;
  --c-stanshop:  #4a8a9b;
  --c-gap:       #2a2f3a;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'IBM Plex Mono', monospace; }
.shell { max-width: 860px; margin: 0 auto; padding: 3rem 1.5rem 8rem; }
.hdr { border-bottom: 1px solid var(--border); padding-bottom: 1.5rem; margin-bottom: 2rem; }
.eyebrow { font-size: 0.52rem; letter-spacing: 0.32em; color: var(--muted); text-transform: uppercase; margin-bottom: 0.4rem; }
.title { font-size: 1.5rem; color: var(--head); font-weight: 300; letter-spacing: 0.04em; }
.sub { font-size: 0.58rem; color: var(--muted); margin-top: 0.4rem; letter-spacing: 0.1em; line-height: 1.6; }
.legend { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 2.5rem; }
.leg { display: flex; align-items: center; gap: 0.35rem; font-size: 0.5rem; letter-spacing: 0.12em; color: var(--muted); text-transform: uppercase; }
.dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.timeline { position: relative; padding-left: 2rem; }
.timeline::before { content: ''; position: absolute; left: 0.25rem; top: 0; bottom: 0; width: 1px; background: var(--line); }
.entry { position: relative; margin-bottom: 0.6rem; }
.entry::before {
  content: '';
  position: absolute;
  left: -1.75rem;
  top: 1rem;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--dot-color, var(--muted));
  box-shadow: 0 0 6px var(--dot-color, transparent);
}
.inner {
  background: var(--card);
  border: 1px solid var(--border);
  border-left: 2px solid var(--dot-color, var(--border));
  padding: 0.65rem 0.9rem;
  border-radius: 2px;
  cursor: pointer;
  transition: border-color 0.15s;
}
.inner:hover { border-color: var(--dot-color); }
.row1 { display: flex; align-items: baseline; gap: 0.75rem; }
.date { font-size: 0.58rem; letter-spacing: 0.18em; color: var(--muted); text-transform: uppercase; min-width: 3.5rem; }
.count { font-size: 0.5rem; letter-spacing: 0.1em; color: var(--dot-color, var(--muted)); opacity: 0.8; }
.name { font-size: 0.72rem; color: var(--head); margin: 0.18rem 0 0.12rem; line-height: 1.45; }
.note-text { font-size: 0.62rem; color: var(--text); line-height: 1.55; }
.sessions-list { margin-top: 0.4rem; padding-top: 0.4rem; border-top: 1px solid var(--border); display: none; }
.sessions-list.open { display: block; }
.s-item { font-size: 0.58rem; color: var(--muted); padding: 0.1rem 0; }
.s-item::before { content: '· '; }
.gap .inner { border-left-color: var(--c-gap); opacity: 0.5; }
.type-milestone { --dot-color: var(--c-milestone); }
.type-crew      { --dot-color: var(--c-crew); }
.type-early     { --dot-color: var(--c-early); }
.type-bridge    { --dot-color: var(--c-bridge); }
.type-stn2      { --dot-color: var(--c-stn2); }
.type-deep      { --dot-color: var(--c-deep); }
.type-research  { --dot-color: var(--c-research); }
.type-today     { --dot-color: var(--c-today); }
.type-stanshop  { --dot-color: var(--c-stanshop); }
.type-gap       { --dot-color: var(--c-gap); }
.stats { font-size: 0.55rem; color: var(--muted); letter-spacing: 0.12em; margin-bottom: 1.5rem; }
</style>

<div class="shell">
  <div class="hdr">
    <div class="eyebrow">&#128204; NEST SESSION TIMELINE — PASS 1</div>
    <h1 class="title">Session Log</h1>
    <div class="sub">
      UNLISTED &#8212; CREW NAVIGATION ONLY<br>
      129 sessions &#183; 28 active days &#183; 0 gaps &#183; Mar 4–Mar 31 2026<br>
      Click any entry to expand session names &#183; Pass 2 adds documents + expanded notes
    </div>
  </div>

  <div class="legend">
    <div class="leg"><div class="dot" style="background:var(--c-milestone)"></div>Milestone</div>
    <div class="leg"><div class="dot" style="background:var(--c-early)"></div>Early chats</div>
    <div class="leg"><div class="dot" style="background:var(--c-crew)"></div>Crew ops</div>
    <div class="leg"><div class="dot" style="background:var(--c-stanshop)"></div>Stan's Shop era</div>
    <div class="leg"><div class="dot" style="background:var(--c-bridge)"></div>Bridge / fleet</div>
    <div class="leg"><div class="dot" style="background:var(--c-stn2)"></div>STN2 logs</div>
    <div class="leg"><div class="dot" style="background:var(--c-deep)"></div>Deep work</div>
    <div class="leg"><div class="dot" style="background:var(--c-research)"></div>Research</div>
    <div class="leg"><div class="dot" style="background:var(--c-today)"></div>Today</div>
  </div>

  <div class="timeline">
    {sessions.map((s, i) => (
      <div class={`entry type-${s.type}`} id={`day-${s.date}`}>
        <div class="inner" onclick={`this.querySelector('.sessions-list').classList.toggle('open')`}>
          <div class="row1">
            <span class="date">{s.label}</span>
            <span class="count">{s.count} session{s.count !== 1 ? 's' : ''}</span>
          </div>
          {s.note && <div class="note-text">{s.note}</div>}
          <div class="sessions-list">
            {s.names.map(n => <div class="s-item">{n}</div>)}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
</BaseLayout>
