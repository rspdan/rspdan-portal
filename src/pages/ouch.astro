---
// rspdan.com/ouch — Zine QR landing. Placeholder until the real experience.
// Box in Box: this page never links to ouchmccouch.com
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>...</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;1,300&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0A0E1A;
      color: #C9A84C;
      font-family: 'Crimson Pro', serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }
    .liam {
      position: relative;
      width: 200px;
      height: 200px;
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      25% { transform: translateY(-20px) rotate(3deg); }
      50% { transform: translateY(-10px) rotate(-2deg); }
      75% { transform: translateY(-25px) rotate(1deg); }
    }
    .liam svg {
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 0 20px rgba(201, 168, 76, 0.3));
    }
    .hint {
      margin-top: 3rem;
      font-size: 1.1rem;
      font-style: italic;
      opacity: 0;
      animation: fadeIn 3s ease-in 2s forwards;
      color: rgba(201, 168, 76, 0.5);
      letter-spacing: 0.1em;
    }
    @keyframes fadeIn {
      to { opacity: 1; }
    }
    .footprints {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 120px;
      display: flex;
      justify-content: center;
      gap: 40px;
      align-items: flex-end;
      padding-bottom: 30px;
      opacity: 0.15;
    }
    .footprint {
      width: 16px;
      height: 28px;
      background: rgba(201, 168, 76, 0.4);
      border-radius: 50% 50% 30% 30%;
      animation: stepIn 4s ease-in forwards;
    }
    .footprint:nth-child(even) { transform: rotate(-8deg); }
    .footprint:nth-child(odd) { transform: rotate(8deg); margin-top: 10px; }
    @keyframes stepIn {
      0% { opacity: 0; }
      100% { opacity: 0.15; }
    }
    .footprint:nth-child(1) { animation-delay: 0.5s; }
    .footprint:nth-child(2) { animation-delay: 1.2s; }
    .footprint:nth-child(3) { animation-delay: 1.9s; }
    .footprint:nth-child(4) { animation-delay: 2.6s; }
    .footprint:nth-child(5) { animation-delay: 3.3s; }
    .footprint:nth-child(6) { animation-delay: 4.0s; }
    .footprint:nth-child(7) { animation-delay: 4.7s; }
  </style>
</head>
<body>
  <!-- Liam: the origami messenger bird -->
  <div class="liam">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <!-- Origami bird - folded from a letter -->
      <g transform="translate(30, 50)">
        <!-- Body (folded paper) -->
        <polygon points="70,0 140,50 70,40 0,50" fill="#C9A84C" opacity="0.9"/>
        <!-- Wing (upper fold) -->
        <polygon points="70,0 110,25 70,20 30,25" fill="#E5D5A0" opacity="0.7">
          <animateTransform attributeName="transform" type="rotate"
            values="0 70 20; -15 70 20; 0 70 20; 10 70 20; 0 70 20"
            dur="3s" repeatCount="indefinite"/>
        </polygon>
        <!-- Tail -->
        <polygon points="0,50 -15,35 10,45" fill="#C9A84C" opacity="0.8"/>
        <!-- Beak -->
        <polygon points="140,50 155,48 140,53" fill="#E5D5A0"/>
        <!-- Eye -->
        <circle cx="130" cy="46" r="2.5" fill="#0A0E1A"/>
        <!-- Fold line (the letter crease) -->
        <line x1="30" y1="25" x2="110" y2="25" stroke="#0A0E1A" stroke-width="0.5" opacity="0.3"/>
        <!-- tiny envelope flap hint -->
        <polygon points="65,20 70,10 75,20" fill="#E5D5A0" opacity="0.3"/>
      </g>
    </svg>
  </div>

  <p class="hint">something is arriving</p>

  <!-- Desaturated footprints - Ouch walking into frame -->
  <div class="footprints">
    <div class="footprint"></div>
    <div class="footprint"></div>
    <div class="footprint"></div>
    <div class="footprint"></div>
    <div class="footprint"></div>
    <div class="footprint"></div>
    <div class="footprint"></div>
  </div>

</body>
</html>
