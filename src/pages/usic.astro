---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Usic" description="The Circle of Colors — Twelve keys mapped to landscape. The Mas Thesis.">

<section class="usic-hero">
  <div class="container">
    <div class="usic-eyebrow mono">The Circle of Colors</div>
    <h1 class="usic-title">Usic</h1>
    <p class="usic-sub">Twelve keys mapped to landscape. Seven natural keys inhale. Five sharp keys exhale. Piralus at the center. Each key holds a region, an ecosystem, a color, and a tone.</p>
  </div>
</section>

<section class="usic-circle">
  <div class="container">
    <div class="circle-wrap">
      <div class="circle-center">Piralus</div>
      <div class="circle-key" style="--angle:0deg;--kc:#E53327"><span class="ck-label">C</span></div>
      <div class="circle-key" style="--angle:30deg;--kc:#31A048"><span class="ck-label">G</span></div>
      <div class="circle-key" style="--angle:60deg;--kc:#D43259"><span class="ck-label">D</span></div>
      <div class="circle-key" style="--angle:90deg;--kc:#ECD31B"><span class="ck-label">A</span></div>
      <div class="circle-key" style="--angle:120deg;--kc:#9376B3"><span class="ck-label">E</span></div>
      <div class="circle-key" style="--angle:150deg;--kc:#F09021"><span class="ck-label">B</span></div>
      <div class="circle-key" style="--angle:180deg;--kc:#80CEE0"><span class="ck-label">F#</span></div>
      <div class="circle-key" style="--angle:210deg;--kc:#9B4F3A"><span class="ck-label">C#</span></div>
      <div class="circle-key" style="--angle:240deg;--kc:#84C44E"><span class="ck-label">G#</span></div>
      <div class="circle-key" style="--angle:270deg;--kc:#B5338A"><span class="ck-label">D#</span></div>
      <div class="circle-key" style="--angle:300deg;--kc:#D4B483"><span class="ck-label">A#</span></div>
      <div class="circle-key" style="--angle:330deg;--kc:#45B7C8"><span class="ck-label">F</span></div>
    </div>
  </div>
</section>

<section class="usic-keys">
  <div class="container">
    <div class="keys-label mono">Natural keys — inhale</div>
    <div class="keys-flow">

      <div class="key-card" style="--kc:#E53327">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">C</span><span class="key-color-name mono">Red</span></div>
        <h3 class="key-range">The Heart → Quiets Source Forest</h3>
        <p class="key-desc">Home. Low Queen Qualia's domain. Interior to muted edge where Ecila drains and Ceila nurtures.</p>
      </div>

      <div class="key-card" style="--kc:#31A048">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">G</span><span class="key-color-name mono">Green</span></div>
        <h3 class="key-range">Quiets → Keylock</h3>
        <p class="key-desc">Interior river to coast gate. The hinge between forest and coast. The lock that opens.</p>
      </div>

      <div class="key-card" style="--kc:#D43259">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">D</span><span class="key-color-name mono">Pink</span></div>
        <h3 class="key-range">Darkive Source Forest → Trap Island</h3>
        <p class="key-desc">Data enters the system, routes to Piralus. D begins the D-A-E coastal run — the shore that spells its own keys.</p>
      </div>

      <div class="key-card" style="--kc:#ECD31B">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">A</span><span class="key-color-name mono">Yellow</span></div>
        <h3 class="key-range">Source Forest → Sh'Doot</h3>
        <p class="key-desc">Rain forest to convergence. Trip's lighthouse. Yellow = sunlight that burns and powers simultaneously.</p>
      </div>

      <div class="key-card" style="--kc:#9376B3">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">E</span><span class="key-color-name mono">Purple</span></div>
        <h3 class="key-range">High King's Territory → EADal Shore</h3>
        <p class="key-desc">Summit to The Darkive. Where the Brush replaces the Sword. Rivers converge into one triangular body at the edge.</p>
      </div>

      <div class="key-card" style="--kc:#F09021">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">B</span><span class="key-color-name mono">Orange</span></div>
        <h3 class="key-range">The Wha → Dewdrop Lake</h3>
        <p class="key-desc">River corridor to lake edge. Splits Niap into left and right hemispheres. The Corridor of Return.</p>
      </div>

      <div class="key-card" style="--kc:#45B7C8">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">F</span><span class="key-color-name mono">Blue</span></div>
        <h3 class="key-range">Fairidge → Fairface</h3>
        <p class="key-desc">Ridge climb to tectonic anchor. F and F# create the Fenning axis — F descends, F# ascends. Both point at Piralus.</p>
      </div>

    </div>

    <div class="keys-label mono" style="margin-top:3rem;">Sharp keys — exhale</div>
    <div class="keys-flow">

      <div class="key-card" style="--kc:#80CEE0">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">F#</span><span class="key-color-name mono">Sky</span></div>
        <h3 class="key-range">Harvestview Top → Niap City</h3>
        <p class="key-desc">Mountain viewpoint to starting city. Where you wake up — you do not arrive. Stan Dalone's RIFT Store.</p>
      </div>

      <div class="key-card" style="--kc:#9B4F3A">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">C#</span><span class="key-color-name mono">Brick</span></div>
        <h3 class="key-range">Reed Krap / Hoyle Face Shin → Squish / Dunge</h3>
        <p class="key-desc">Rain shadow country. Two interior landmarks, two exterior. Reed Krap nearest F#, Hoyle Face Shin nearest G#.</p>
      </div>

      <div class="key-card" style="--kc:#84C44E">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">G#</span><span class="key-color-name mono">Lime</span></div>
        <h3 class="key-range">Mystery Camp → Eyer Land</h3>
        <p class="key-desc">The Unknown to the islands. Named for the experience of being lost. Ireland + eye + eyre + island.</p>
      </div>

      <div class="key-card" style="--kc:#B5338A">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">D#</span><span class="key-color-name mono">Magenta</span></div>
        <h3 class="key-range">Steampipes → Steambridge</h3>
        <p class="key-desc">Eastern approach. The Steam key — the prefix carries you the whole way. Steamford is the backdrop beyond.</p>
      </div>

      <div class="key-card" style="--kc:#D4B483">
        <div class="key-color-bar"></div>
        <div class="key-head"><span class="key-note mono">A#</span><span class="key-color-name mono">Tan</span></div>
        <h3 class="key-range">A##A A##A → The Steam Yards</h3>
        <p class="key-desc">Absurd interior to shipyards. Always twice, always unreadable. Don'te is the backdrop beyond.</p>
      </div>

    </div>
  </div>
</section>

<section class="usic-close">
  <div class="container">
    <p class="close-text">The name doesn't create the place. The place creates the name.</p>
    <p class="close-meta mono">Waywood Principle #1</p>
  </div>
</section>

<style>
.usic-hero{padding:6rem 0 4rem;background:linear-gradient(160deg,#1a2e28 0%,var(--forest) 60%);border-bottom:2px solid var(--teal);}
.usic-eyebrow{font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--teal);margin-bottom:0.75rem;}
.usic-title{font-family:var(--font-head);font-size:clamp(3rem,8vw,5rem);color:var(--warm-white);line-height:1;margin-bottom:1.25rem;letter-spacing:-0.02em;}
.usic-sub{font-size:1.05rem;color:rgba(255,255,255,0.7);max-width:580px;line-height:1.8;}

.usic-circle{padding:4rem 0;background:var(--off-white);}
.circle-wrap{position:relative;width:340px;height:340px;margin:0 auto;}
.circle-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:var(--font-head);font-size:1.1rem;color:var(--forest);font-weight:600;}
.circle-key{position:absolute;top:50%;left:50%;width:44px;height:44px;border-radius:50%;background:var(--kc);display:flex;align-items:center;justify-content:center;transform:rotate(var(--angle)) translateY(-140px) rotate(calc(-1 * var(--angle)));margin:-22px 0 0 -22px;box-shadow:0 2px 8px rgba(0,0,0,0.12);}
.ck-label{font-family:var(--font-mono);font-size:0.7rem;font-weight:700;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,0.3);}

.usic-keys{padding:4rem 0;}
.keys-label{font-size:0.6rem;letter-spacing:0.25em;color:var(--forest);margin-bottom:1.5rem;text-transform:uppercase;}
.keys-flow{display:flex;flex-wrap:wrap;gap:1.25rem;}
.key-card{flex:1 1 300px;max-width:400px;background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;border-left:3px solid var(--kc);}
.key-head{display:flex;align-items:baseline;gap:0.75rem;margin-bottom:0.5rem;}
.key-note{font-size:1.2rem;font-weight:700;color:var(--kc);}
.key-color-name{font-size:0.6rem;letter-spacing:0.15em;color:var(--kc);}
.key-color-bar{display:none;}
.key-range{font-family:var(--font-head);font-size:1.05rem;color:var(--text);margin-bottom:0.5rem;line-height:1.4;}
.key-desc{font-size:0.85rem;color:var(--text-lt);line-height:1.7;}

.usic-close{padding:4rem 0;background:var(--forest);text-align:center;}
.close-text{font-family:var(--font-head);font-size:clamp(1.2rem,2.5vw,1.65rem);color:var(--warm-white);font-style:italic;margin-bottom:1rem;max-width:700px;margin-left:auto;margin-right:auto;line-height:1.65;}
.close-meta{font-size:0.6rem;letter-spacing:0.2em;color:var(--teal);}

@media(max-width:640px){
  .circle-wrap{width:280px;height:280px;}
  .circle-key{width:36px;height:36px;margin:-18px 0 0 -18px;transform:rotate(var(--angle)) translateY(-110px) rotate(calc(-1 * var(--angle)));}
  .ck-label{font-size:0.6rem;}
  .keys-flow{flex-direction:column;}
  .key-card{max-width:100%;}
}
</style>
</BaseLayout>
