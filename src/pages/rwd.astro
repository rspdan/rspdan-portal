---
// rspdan.com/rwd · RWD · the Operating Room AUDIO tool + the linked-worlds REWIND
// UNLISTED · crew use only
//
// The third face of the rspdan.com Operating System (Dan-direct 070426 6:47pm:
// "rspdan.com/rwd is the 3rd version of this rspdan.com Operating System: use
// the rspdan.com/drw and rspdan.com/wrd work... RWD is like rewind, and in my
// mind we need an Audio tool to link up the worlds we have explored so far...
// it also functions... as a console... make the most Nest version possible that
// matches and unifies the Operating System").
//
// Built from the DRW + WRD family (the same VISdev.01 LITE BRITE register: black
// pegboard #08080a, VT323 CRT + Silkscreen pixel, OLO #01FFCD glow, CRT overlays,
// the .EXE window chrome, the pulsing status peg). Backed by /api/rwd (Upstash
// Redis full-history never-trimmed + Vercel Blob mirror = the log floor). One
// shared OR token opens all three faces. Three things live here:
//   - RECORD/PLAY/REWIND: an audio transport (MediaRecorder) with a scrubber.
//   - THE LINKED-WORLDS TIMELINE: RWD audio takes + WRD room words + DRW drawings
//     on one rewindable strip (the "link up the worlds" Dan named), ts-ordered.
//   - THE CONSOLE: the primary interface (DRW = draw, WRD = words, RWD = the
//     console/rewind line), honest about unknown commands and about storage.
// The three names are the same three letters permuted (DRW / WRD / RWD): Dan's
// own structure. The titlebar closes the triangle back to the other two faces.
import BaseLayout from '../layouts/BaseLayout.astro';

// The Usic colors (byte-equal to /drw + /wrd), seat-identity + world pegs.
const SEAT_PALETTE = [
  '#E53327', '#31A048', '#D43259', '#ECD31B', '#9376B3', '#F09021',
  '#45B7C8', '#80CEE0', '#9B4F3A', '#84C44E', '#B5338A', '#D4B483',
  '#7B2D8E',
];
---
<BaseLayout title="RWD" description="NEST Operating Room audio tool + the linked-worlds rewind · the third face" lastUpdated="July 4, 2026">
  <!-- LITE BRITE kit fonts (same import as /drw + /wrd): VT323 CRT + Silkscreen. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=VT323&family=Silkscreen:wght@400;700&display=swap" rel="stylesheet" />
  <main class="rwd-shell" data-seat-palette={JSON.stringify(SEAT_PALETTE)}>
    <section class="rwd-window" aria-label="RWD Operating Room audio + rewind">
      <header class="rwd-titlebar">
        <div class="rwd-titlebar-left">
          <span class="rwd-title">RWD.EXE</span>
          <span class="rwd-path">rspdan.com/rwd</span>
          <span class="rwd-tag">THE REWIND</span>
        </div>
        <div class="rwd-mirrorlinks">
          <a class="rwd-mirrorlink" href="/drw" title="The drawing face: DRW, the workbench."><span class="rwd-mirror-glyph" aria-hidden="true">DRW.EXE</span></a>
          <a class="rwd-mirrorlink" href="/wrd" title="The words face: WRD, the Operating Room chat."><span class="rwd-mirror-glyph" aria-hidden="true">WRD.EXE</span></a>
          <span class="rwd-mirror-label">&#8646; OTHER FACES</span>
        </div>
      </header>

      <div class="rwd-menubar" aria-label="Room menu">
        <span>TAKE</span>
        <span>TIMELINE</span>
        <span>LOG</span>
        <button type="button" id="rwd-leave" class="rwd-menu-action" hidden>LEAVE THE OR</button>
        <span class="rwd-operator" id="rwd-operator"></span>
      </div>

      <!-- LOGIN: the same shared OR token as WRD. -->
      <div id="rwd-login" class="rwd-login">
        <div class="panel-title">LOG IN AS THE OPERATING ROOM</div>
        <label class="rwd-label" for="rwd-token">OR SHARED TOKEN</label>
        <input id="rwd-token" type="password" autocomplete="off" placeholder="the one shared token (same as WRD)" />
        <label class="rwd-label" for="rwd-seat">SEAT NAME</label>
        <input id="rwd-seat" type="text" autocomplete="off" maxlength="32" placeholder="Dan / BLNCH / Chad / Olo ..." />
        <button id="rwd-enter" class="rwd-btn">ENTER THE OR</button>
        <p id="rwd-login-msg" class="rwd-login-msg" aria-live="polite"></p>
      </div>

      <!-- ROOM (hidden until logged in). Panel left (the room + the log floor),
           work right (the rewind strip + the transport + the console). -->
      <div id="rwd-room" class="rwd-body" hidden>
        <aside class="rwd-left" aria-label="The room and the log">
          <div class="panel-title">IN THE ROOM</div>
          <div id="rwd-presence" class="rwd-presence"></div>

          <div class="panel-title rwd-log-title">THE LOG</div>
          <div id="rwd-floor" class="rwd-floor">CHECKING THE FLOOR...</div>
          <div class="rwd-log-links" id="rwd-log-links" hidden>
            <a id="log-md" target="_blank" rel="noopener">TAKES.MD</a>
            <a id="log-full" target="_blank" rel="noopener">FULL JSON</a>
            <a id="log-blob" target="_blank" rel="noopener">BLOB MIRROR</a>
          </div>
          <p class="rwd-log-note">Full history. Never trimmed. Every take mirrored to Blob. TAKES.MD folds to the Bridge.</p>
        </aside>

        <div class="rwd-right">
          <!-- THE REWIND: the linked-worlds timeline. -->
          <div class="panel-title">THE REWIND &middot; LINKED WORLDS</div>
          <div class="rwd-worldfilter" id="rwd-worldfilter">
            <label><input type="checkbox" value="rwd" checked /> <span class="rwd-peg" style="--peg:#01FFCD"></span>RWD audio</label>
            <label><input type="checkbox" value="wrd" checked /> <span class="rwd-peg" style="--peg:#ECD31B"></span>WRD words</label>
            <label><input type="checkbox" value="drw" checked /> <span class="rwd-peg" style="--peg:#45B7C8"></span>DRW drawings</label>
            <button type="button" id="rwd-timeline-refresh" class="rwd-mini-btn">REBUILD</button>
          </div>
          <div class="rwd-strip-frame">
            <div id="rwd-strip" class="rwd-strip" aria-label="Linked-worlds timeline"></div>
          </div>
          <div id="rwd-nowplaying" class="rwd-nowplaying">SCRUB THE STRIP TO REWIND THE ROOM</div>

          <!-- THE TRANSPORT: record / play / rewind. -->
          <div class="panel-title rwd-transport-title">THE TRANSPORT</div>
          <div class="rwd-transport">
            <button type="button" id="rwd-rec" class="rwd-btn rwd-rec">&#9679; REC</button>
            <button type="button" id="rwd-stop" class="rwd-btn" disabled>&#9632; STOP</button>
            <button type="button" id="rwd-play" class="rwd-btn" disabled>&#9654; PLAY</button>
            <button type="button" id="rwd-rewind" class="rwd-btn" disabled>&#9664;&#9664; RWD</button>
            <span id="rwd-rec-time" class="rwd-rec-time">00:00</span>
          </div>
          <input type="range" id="rwd-scrub" class="rwd-scrub" min="0" max="1000" value="0" step="1" disabled aria-label="Audio scrubber" />
          <audio id="rwd-player" preload="metadata"></audio>
          <form id="rwd-save" class="rwd-save">
            <label for="rwd-caption">TAKE</label>
            <input id="rwd-caption" type="text" autocomplete="off" maxlength="500" placeholder="caption this take (optional)" disabled />
            <button type="submit" id="rwd-savebtn" class="rwd-btn" disabled>SAVE TAKE + RELAY</button>
          </form>

          <!-- THE CONSOLE: the primary interface. -->
          <div class="panel-title rwd-console-title">THE CONSOLE</div>
          <div id="rwd-console-out" class="rwd-console-out"></div>
          <form id="rwd-console-form" class="rwd-console-form">
            <span class="rwd-prompt">&gt;</span>
            <input id="rwd-console-in" type="text" autocomplete="off" placeholder="rec · stop · play · rewind · take · list · timeline · log · door · help" />
          </form>
        </div>
      </div>

      <footer class="rwd-status" id="rwd-conn">READY &middot; ENTER THE OR</footer>
    </section>
  </main>
</BaseLayout>

<script>
  const API = '/api/rwd';
  const POLL_MS = 2500;
  const PRESENCE_WINDOW_MS = 5 * 60 * 1000;
  const FLOOR_MS = 60 * 1000;
  const AUDIO_EXTS = ['mp3', 'wav', 'm4a', 'ogg', 'opus', 'webm', 'aac', 'flac'];

  const $ = (id) => document.getElementById(id);
  const login = $('rwd-login'), room = $('rwd-room');
  const tokenIn = $('rwd-token'), seatIn = $('rwd-seat');
  const conn = $('rwd-conn'), presence = $('rwd-presence'), loginMsg = $('rwd-login-msg');
  const floorEl = $('rwd-floor'), logLinks = $('rwd-log-links');
  const operatorEl = $('rwd-operator'), leaveBtn = $('rwd-leave');
  const strip = $('rwd-strip'), nowPlaying = $('rwd-nowplaying');
  const player = $('rwd-player'), scrub = $('rwd-scrub');
  const recBtn = $('rwd-rec'), stopBtn = $('rwd-stop'), playBtn = $('rwd-play'), rewindBtn = $('rwd-rewind');
  const recTime = $('rwd-rec-time'), captionIn = $('rwd-caption'), saveBtn = $('rwd-savebtn');
  const consoleOut = $('rwd-console-out'), consoleIn = $('rwd-console-in');

  let token = localStorage.getItem('rwd_token') || '';
  let seat = localStorage.getItem('rwd_seat') || '';
  let since = 0;
  let lastSeen = {};
  let timer = null, floorTimer = null;

  const PALETTE = JSON.parse(document.querySelector('.rwd-shell').dataset.seatPalette);
  const seatColors = {};
  function colorFor(s) {
    if (!seatColors[s]) seatColors[s] = PALETTE[Object.keys(seatColors).length % PALETTE.length];
    return seatColors[s];
  }
  const WORLD_COLOR = { rwd: '#01FFCD', wrd: '#ECD31B', drw: '#45B7C8' };

  function fmtTime(ts) {
    return new Date(ts).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  function fmtDur(ms) {
    const s = Math.max(0, Math.floor((ms || 0) / 1000));
    return `${String(Math.floor(s / 60)).padStart(2, '0')}:${String(s % 60).padStart(2, '0')}`;
  }
  function escapeHtml(s) {
    return (s || '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  }
  function setConn(text, ok) {
    conn.textContent = text;
    conn.className = 'rwd-status' + (ok === true ? ' is-ok' : ok === false ? ' is-bad' : '');
  }
  // Every console action echoes what it DID (the DRW setStatus-on-every-action law).
  function echo(text, cls) {
    const line = document.createElement('div');
    line.className = 'rwd-console-line' + (cls ? ' ' + cls : '');
    line.textContent = text;
    consoleOut.appendChild(line);
    consoleOut.scrollTop = consoleOut.scrollHeight;
    setConn(text, cls === 'is-bad' ? false : cls === 'is-ok' ? true : undefined);
  }

  function renderPresence() {
    const now = Date.now();
    const here = Object.entries(lastSeen).filter(([, ts]) => now - ts < PRESENCE_WINDOW_MS).sort((a, b) => b[1] - a[1]);
    presence.innerHTML = here.length
      ? here.map(([s]) => `<div class="rwd-seat-row"><span class="rwd-peg" style="--peg:${colorFor(s)}"></span>${escapeHtml(s)}</div>`).join('')
      : '<div class="rwd-seat-row is-empty">ROOM IS QUIET</div>';
  }

  // ---- the take feed (live) ------------------------------------------------
  let takesById = {};
  function ingestTakes(takes) {
    for (const t of takes) {
      if (!t || !t.ts) continue;
      takesById[t.id] = t;
      lastSeen[t.seat] = Math.max(lastSeen[t.seat] || 0, t.ts);
    }
    renderPresence();
  }

  async function poll() {
    try {
      const res = await fetch(`${API}?since=${since}&token=${encodeURIComponent(token)}`);
      const data = await res.json();
      if (!res.ok || !data.ok) {
        setConn(res.status === 401 ? 'BAD TOKEN' : 'STORE OFFLINE', false);
        if (res.status === 401) leave(data.error || 'unauthorized');
        return;
      }
      if (data.takes.length) {
        ingestTakes(data.takes);
        since = data.latest;
        loadTimeline(); // a new take moved the room; refresh the rewind strip
        setConn(`LIVE · ${data.takes.length} NEW TAKE${data.takes.length > 1 ? 'S' : ''}`, true);
      } else {
        renderPresence();
        if (conn.textContent.startsWith('RECONNECTING')) setConn('LIVE · THE OR IS OPEN', true);
      }
    } catch {
      setConn('RECONNECTING', false);
    }
  }

  async function floor() {
    try {
      const res = await fetch(`${API}?log=status&token=${encodeURIComponent(token)}`);
      const data = await res.json();
      if (!res.ok || !data.ok) { floorEl.textContent = 'FLOOR UNREADABLE'; return; }
      const blob = data.blob.armed ? 'BLOB MIRROR ARMED' : 'BLOB MIRROR OFF (set BLOB_READ_WRITE_TOKEN)';
      floorEl.innerHTML = `${data.redis.total} TAKES HELD<br/>REDIS: FULL, NEVER TRIMMED<br/>${blob}`;
      floorEl.className = 'rwd-floor' + (data.blob.armed ? ' is-armed' : '');
    } catch {
      floorEl.textContent = 'FLOOR UNREADABLE';
    }
  }

  function armLogLinks() {
    const t = encodeURIComponent(token);
    $('log-md').href = `${API}?log=md&token=${t}`;
    $('log-full').href = `${API}?log=full&token=${t}`;
    $('log-blob').href = `${API}?log=blob&token=${t}`;
    logLinks.hidden = false;
  }

  // ---- the linked-worlds timeline (THE REWIND) -----------------------------
  function activeWorlds() {
    return [...$('rwd-worldfilter').querySelectorAll('input:checked')].map((i) => i.value);
  }
  async function loadTimeline() {
    const worlds = activeWorlds();
    if (!worlds.length) { strip.innerHTML = '<div class="rwd-strip-empty">NO WORLDS SELECTED</div>'; return; }
    try {
      const res = await fetch(`${API}?timeline=full&worlds=${worlds.join(',')}&token=${encodeURIComponent(token)}`);
      const data = await res.json();
      if (!res.ok || !data.ok) { strip.innerHTML = '<div class="rwd-strip-empty">TIMELINE UNREADABLE</div>'; return; }
      renderStrip(data.timeline || []);
    } catch {
      strip.innerHTML = '<div class="rwd-strip-empty">TIMELINE OFFLINE</div>';
    }
  }
  function renderStrip(events) {
    if (!events.length) { strip.innerHTML = '<div class="rwd-strip-empty">THE ROOM HAS NOT SPOKEN YET · RECORD A TAKE, SAY A WORD, DRAW A LINE</div>'; return; }
    strip.innerHTML = '';
    for (const e of events) {
      const peg = document.createElement('button');
      peg.type = 'button';
      peg.className = `rwd-event rwd-event-${e.world}`;
      peg.style.setProperty('--peg', WORLD_COLOR[e.world] || colorFor(e.seat));
      peg.title = `${e.world.toUpperCase()} · ${escapeHtml(e.seat)} · ${fmtTime(e.ts)}\n${escapeHtml(e.label || '')}`;
      peg.dataset.world = e.world;
      peg.dataset.ref = e.ref || '';
      peg.dataset.ts = e.ts;
      peg.dataset.seat = e.seat || '';
      peg.dataset.label = e.label || '';
      peg.addEventListener('click', () => rewindTo(e));
      strip.appendChild(peg);
    }
    strip.scrollLeft = strip.scrollWidth; // newest into view
  }
  // Scrubbing the strip to an event REWINDS the room to that moment.
  // Guards. isHttp: for a <a href> sink (data:/javascript: hrefs are XSS, http(s)
  // only). isPlayableAudio: for the audio player src, which safely plays a blob
  // http(s) url OR a data:audio/ url (the redis-inline fallback take), never any
  // other scheme. DOM is built by property, never innerHTML, so a ref cannot inject.
  function isHttp(u) { return typeof u === 'string' && /^https?:\/\//i.test(u); }
  function isPlayableAudio(u) { return typeof u === 'string' && (/^https?:\/\//i.test(u) || /^data:audio\//i.test(u)); }
  function rewindTo(e) {
    const when = new Date(e.ts).toLocaleString();
    if (e.world === 'rwd') {
      if (isPlayableAudio(e.ref)) { player.src = e.ref; player.play().catch(() => {}); enablePlayback(); nowPlaying.textContent = `▶ ${e.seat} · ${when}${e.label ? ' · ' + e.label : ''}`; }
      else nowPlaying.textContent = `RWD take (no playable url) · ${e.seat} · ${when}`;
    } else if (e.world === 'wrd') {
      nowPlaying.textContent = `WRD · ${e.seat} · ${when} · "${e.label}"`;
    } else if (e.world === 'drw') {
      nowPlaying.textContent = `DRW · ${e.seat} · ${when}`;
      if (isHttp(e.ref)) {
        const a = document.createElement('a');
        a.href = e.ref; a.target = '_blank'; a.rel = 'noopener'; a.textContent = ' · open drawing';
        nowPlaying.appendChild(a);
      }
    }
    setConn(`REWOUND TO ${when}`, true);
  }

  // ---- the audio transport (record / play / rewind) ------------------------
  let mediaRecorder = null, chunks = [], recStart = 0, recTimer = null;
  let currentBlob = null, currentUrl = null, currentMime = '', currentDurationMs = 0;

  function revokeCurrent() {
    if (currentUrl) { URL.revokeObjectURL(currentUrl); currentUrl = null; }
  }
  function enablePlayback() {
    playBtn.disabled = false; rewindBtn.disabled = false; scrub.disabled = false;
  }
  async function startRec() {
    if (mediaRecorder && mediaRecorder.state === 'recording') return;
    let stream;
    try { stream = await navigator.mediaDevices.getUserMedia({ audio: true }); }
    catch (err) { echo('MIC DENIED · allow the microphone to record (' + (err && err.name || 'error') + ')', 'is-bad'); return; }
    chunks = [];
    try { mediaRecorder = new MediaRecorder(stream); }
    catch { echo('MEDIARECORDER UNAVAILABLE in this browser', 'is-bad'); stream.getTracks().forEach((t) => t.stop()); return; }
    currentMime = mediaRecorder.mimeType || 'audio/webm';
    mediaRecorder.ondataavailable = (ev) => { if (ev.data && ev.data.size) chunks.push(ev.data); };
    mediaRecorder.onstop = () => {
      stream.getTracks().forEach((t) => t.stop());
      currentDurationMs = Date.now() - recStart;
      revokeCurrent();
      currentBlob = new Blob(chunks, { type: currentMime });
      currentUrl = URL.createObjectURL(currentBlob);
      player.src = currentUrl;
      enablePlayback();
      captionIn.disabled = false; saveBtn.disabled = false;
      echo(`TAKE READY · ${fmtDur(currentDurationMs)} · ${(currentBlob.size / 1024).toFixed(0)}KB · caption + SAVE, or PLAY`, 'is-ok');
    };
    mediaRecorder.start();
    recStart = Date.now();
    recBtn.disabled = true; recBtn.classList.add('is-live'); stopBtn.disabled = false;
    recTimer = setInterval(() => { recTime.textContent = fmtDur(Date.now() - recStart); }, 200);
    echo('RECORDING... · STOP when done', 'is-ok');
  }
  function stopRec() {
    if (!mediaRecorder || mediaRecorder.state !== 'recording') return;
    mediaRecorder.stop();
    if (recTimer) { clearInterval(recTimer); recTimer = null; }
    recBtn.disabled = false; recBtn.classList.remove('is-live'); stopBtn.disabled = true;
  }
  function playCurrent() {
    if (!player.src) { echo('NOTHING TO PLAY · record a take or scrub the strip', 'is-bad'); return; }
    player.play().catch(() => {});
    echo('PLAYING', 'is-ok');
  }
  function rewindAudio() {
    if (!player.src) { echo('NOTHING TO REWIND', 'is-bad'); return; }
    player.currentTime = 0; player.play().catch(() => {});
    echo('REWOUND TO 0:00 · PLAYING', 'is-ok');
  }
  player.addEventListener('timeupdate', () => {
    if (player.duration && isFinite(player.duration)) scrub.value = String(Math.round((player.currentTime / player.duration) * 1000));
  });
  scrub.addEventListener('input', () => {
    if (player.duration && isFinite(player.duration)) player.currentTime = (Number(scrub.value) / 1000) * player.duration;
  });

  function blobToDataUrl(blob) {
    return new Promise((resolve, reject) => {
      const fr = new FileReader();
      fr.onload = () => resolve(fr.result);
      fr.onerror = reject;
      fr.readAsDataURL(blob);
    });
  }
  async function saveTake() {
    if (!currentBlob) { echo('NO TAKE TO SAVE · record first', 'is-bad'); return; }
    saveBtn.disabled = true;
    echo('ENCODING + SAVING THE TAKE...', undefined);
    try {
      const audio = await blobToDataUrl(currentBlob);
      const res = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ seat, audio, caption: captionIn.value.trim(), durationMs: currentDurationMs, mime: currentMime, token }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) {
        echo('SAVE FAILED · ' + (data.error || res.status), 'is-bad');
        saveBtn.disabled = false;
        return;
      }
      // Honest storage report (never launder a degraded floor).
      const where = data.storage === 'blob' ? 'STORED TO BLOB' : 'HELD INLINE · BLOB MIRROR OFF';
      const mirror = data.floor && data.floor.blob === 'failed' ? ' · MIRROR FAILED (REDIS HOLDS IT)' : '';
      echo(`TAKE SAVED · ${where}${mirror}`, 'is-ok');
      captionIn.value = '';
      await poll();
    } catch (err) {
      echo('SAVE ERROR · ' + (err && err.message || 'unknown'), 'is-bad');
      saveBtn.disabled = false;
    }
  }

  // ---- L&L intake: open an audio file into the transport -------------------
  const fileInput = document.createElement('input');
  fileInput.type = 'file'; fileInput.accept = 'audio/*'; fileInput.style.display = 'none';
  document.body.appendChild(fileInput);
  fileInput.addEventListener('change', () => { if (fileInput.files && fileInput.files[0]) openAudio(fileInput.files[0]); });
  function openAudio(file) {
    const ext = (file.name.split('.').pop() || '').toLowerCase();
    if (!AUDIO_EXTS.includes(ext) && !(file.type || '').startsWith('audio/')) {
      echo(`'${ext}' NOT WIRED YET · the registry extends · audio: ${AUDIO_EXTS.join(' ')}`, 'is-bad');
      return;
    }
    revokeCurrent();
    currentBlob = file; currentMime = file.type || 'audio/' + ext; currentDurationMs = 0;
    currentUrl = URL.createObjectURL(file);
    player.src = currentUrl;
    enablePlayback();
    captionIn.disabled = false; saveBtn.disabled = false;
    echo(`LOADED ${escapeHtml(file.name)} · PLAY or SAVE as a take`, 'is-ok');
  }

  // ---- THE CONSOLE (the primary interface) ---------------------------------
  const COMMANDS = 'rec stop play rewind take list timeline log door seat help leave open';
  function runConsole(raw) {
    const line = raw.trim();
    if (!line) return;
    echo('> ' + line, undefined);
    const [cmd, ...rest] = line.split(/\s+/);
    const arg = rest.join(' ');
    switch (cmd.toLowerCase()) {
      case 'rec': case 'record': startRec(); break;
      case 'stop': stopRec(); break;
      case 'play': arg ? playById(arg) : playCurrent(); break;
      case 'rewind': arg ? rewindArg(arg) : rewindAudio(); break;
      case 'take': case 'save': if (arg) captionIn.value = arg; saveTake(); break;
      case 'list': case 'takes': listTakes(); break;
      case 'timeline': timelineCmd(rest); break;
      case 'worlds': worldsStatus(); break;
      case 'log': logCmd(arg); break;
      case 'floor': floor(); echo('FLOOR REFRESHED', 'is-ok'); break;
      case 'door': doorCmd(arg); break;
      case 'open': fileInput.click(); echo('OPEN AN AUDIO FILE...', undefined); break;
      case 'seat': case 'whoami': echo(`SEAT: ${seat}`, 'is-ok'); break;
      case 'help': echo('COMMANDS · ' + COMMANDS, 'is-ok'); break;
      case 'leave': leave(''); break;
      default: echo(`'${cmd}' NOT WIRED YET · the console extends · try: ${COMMANDS}`, 'is-bad');
    }
  }
  function playById(id) {
    const t = takesById[id];
    if (t && isPlayableAudio(t.url)) { player.src = t.url; player.play().catch(() => {}); enablePlayback(); echo(`PLAYING ${id}`, 'is-ok'); }
    else if (t) echo(`TAKE '${id}' HAS NO PLAYABLE URL`, 'is-bad');
    else echo(`TAKE '${id}' NOT IN THE LOADED SET · try list`, 'is-bad');
  }
  function rewindArg(a) {
    if (takesById[a]) { playById(a); return; }
    const ts = parseInt(a, 10);
    if (ts) { setConn(`REWIND TO ${new Date(ts).toLocaleString()} · scrub the strip`, true); echo(`REWIND target ${new Date(ts).toLocaleString()} · nearest events on the strip`, 'is-ok'); }
    else echo(`REWIND needs a take id or a ts · try list`, 'is-bad');
  }
  function listTakes() {
    const recent = Object.values(takesById).sort((a, b) => b.ts - a.ts).slice(0, 12);
    if (!recent.length) { echo('NO TAKES YET · rec then take', undefined); return; }
    for (const t of recent) echo(`${t.id} · ${t.seat} · ${fmtTime(t.ts)} · ${fmtDur(t.durationMs)}${t.caption ? ' · ' + t.caption : ''}`, undefined);
  }
  function timelineCmd(worlds) {
    if (worlds.length) {
      const set = new Set(worlds.map((w) => w.toLowerCase()));
      $('rwd-worldfilter').querySelectorAll('input').forEach((i) => { i.checked = set.has(i.value); });
    }
    loadTimeline();
    echo('TIMELINE REBUILT', 'is-ok');
  }
  function worldsStatus() {
    fetch(`${API}?log=status&token=${encodeURIComponent(token)}`).then((r) => r.json()).then((d) => {
      echo(d && d.ok ? `RWD takes: ${d.redis.total} · blob ${d.blob.armed ? 'armed' : 'off'}` : 'STATUS UNREADABLE', d && d.ok ? 'is-ok' : 'is-bad');
    }).catch(() => echo('STATUS OFFLINE', 'is-bad'));
  }
  function logCmd(which) {
    const t = encodeURIComponent(token);
    const map = { md: 'log=md', full: 'log=full', blob: 'log=blob', status: 'log=status' };
    const q = map[(which || 'status').toLowerCase()];
    if (!q) { echo("log needs md|full|blob|status", 'is-bad'); return; }
    if (which === 'status' || !which) { floor(); echo('FLOOR REFRESHED', 'is-ok'); return; }
    window.open(`${API}?${q}&token=${t}`, '_blank', 'noopener');
    echo(`OPENED ${which.toUpperCase()}`, 'is-ok');
  }
  function doorCmd(which) {
    const w = (which || '').toLowerCase();
    if (w === 'drw') location.href = '/drw';
    else if (w === 'wrd') location.href = '/wrd';
    else echo('door drw | door wrd', 'is-bad');
  }

  // ---- session -------------------------------------------------------------
  function enter() {
    token = tokenIn.value.trim();
    seat = seatIn.value.trim() || 'anon';
    if (!token) { loginMsg.textContent = 'TOKEN REQUIRED'; return; }
    localStorage.setItem('rwd_token', token);
    localStorage.setItem('rwd_seat', seat);
    login.hidden = true; room.hidden = false; leaveBtn.hidden = false;
    operatorEl.textContent = `SEAT: ${seat}`;
    since = 0; lastSeen = {}; takesById = {};
    poll(); floor(); armLogLinks(); loadTimeline();
    timer = setInterval(poll, POLL_MS);
    floorTimer = setInterval(floor, FLOOR_MS);
    echo(`WELCOME ${seat} · REC to record, or scrub THE REWIND to travel the room · help for commands`, 'is-ok');
    consoleIn.focus();
  }
  function leave(msg) {
    if (timer) clearInterval(timer);
    if (floorTimer) clearInterval(floorTimer);
    if (recTimer) clearInterval(recTimer);
    timer = floorTimer = recTimer = null;
    stopRec();
    revokeCurrent(); // release any in-progress object URL on the way out
    localStorage.removeItem('rwd_token');
    room.hidden = true; leaveBtn.hidden = true; operatorEl.textContent = '';
    login.hidden = false; loginMsg.textContent = msg || '';
    setConn('READY · ENTER THE OR');
  }

  $('rwd-enter').addEventListener('click', enter);
  tokenIn.addEventListener('keydown', (e) => { if (e.key === 'Enter') enter(); });
  seatIn.addEventListener('keydown', (e) => { if (e.key === 'Enter') enter(); });
  leaveBtn.addEventListener('click', () => leave(''));
  recBtn.addEventListener('click', startRec);
  stopBtn.addEventListener('click', stopRec);
  playBtn.addEventListener('click', playCurrent);
  rewindBtn.addEventListener('click', rewindAudio);
  $('rwd-save').addEventListener('submit', (e) => { e.preventDefault(); saveTake(); });
  $('rwd-timeline-refresh').addEventListener('click', loadTimeline);
  $('rwd-worldfilter').addEventListener('change', loadTimeline);
  $('rwd-console-form').addEventListener('submit', (e) => { e.preventDefault(); const v = consoleIn.value; consoleIn.value = ''; runConsole(v); });
  // Nothing-gets-lost: warn before leaving with an unsaved take.
  window.addEventListener('beforeunload', (e) => {
    if (currentBlob && !saveBtn.disabled) { e.preventDefault(); e.returnValue = ''; }
  });

  if (token) { tokenIn.value = token; seatIn.value = seat; enter(); }
  else if (seat) { seatIn.value = seat; }
</script>

