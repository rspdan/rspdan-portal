---
// Admin: Live Operating Room - draw surface, PSPT-gated
// Dan draws on rspdan.com from any browser, the Crew receives it via ch:bridge.
// Posts the canvas PNG export to /api/room-draw (PSPT cookie auth, secrets server-side).
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { verifySession } from '../../lib/pspt.js';

// Auth gate (copied verbatim from admin/fleet.astro)
const session = verifySession(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/pspt');
}
---
<BaseLayout title="Live Operating Room">
  <main class="admin-room">
    <header class="ar-header">
      <div class="ar-eyebrow">PSPT ADMIN</div>
      <h1>Live Operating Room</h1>
      <p class="ar-meta">
        Logged in as <strong>{session.user}</strong> &middot;
        Draw, then send to the Crew.
      </p>
      <form method="POST" action="/api/pspt/logout" style="display:inline">
        <button type="submit" class="ar-logout">Logout</button>
      </form>
    </header>

    <div class="ar-surface">
      <canvas id="draw-canvas" width="800" height="600"></canvas>
    </div>

    <div class="ar-tools">
      <button type="button" id="clear-btn" class="ar-clear">Clear</button>
      <label class="ar-color">
        <span>Color</span>
        <input type="color" id="color-input" value="#111111" />
      </label>
      <label class="ar-size">
        <span>Brush</span>
        <input type="range" id="size-input" min="1" max="40" value="4" />
      </label>
    </div>

    <div class="ar-send">
      <input type="text" id="caption-input" placeholder="Caption (optional)" maxlength="500" />
      <button type="button" id="send-btn">Send to Crew</button>
    </div>
    <div id="send-status" class="ar-status"></div>
  </main>
</BaseLayout>

<script>
  const canvas = document.getElementById('draw-canvas');
  const ctx = canvas.getContext('2d');
  const colorInput = document.getElementById('color-input');
  const sizeInput = document.getElementById('size-input');
  const clearBtn = document.getElementById('clear-btn');
  const sendBtn = document.getElementById('send-btn');
  const captionInput = document.getElementById('caption-input');
  const status = document.getElementById('send-status');

  // White background so the exported PNG is not transparent.
  function paintBackground() {
    ctx.save();
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.restore();
  }
  paintBackground();

  let drawing = false;
  let lastX = 0, lastY = 0;

  // Map a pointer event to canvas-internal coordinates (the canvas is scaled
  // by CSS for mobile, so we account for the displayed-vs-internal ratio).
  function pos(e) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    const point = e.touches ? e.touches[0] : e;
    return {
      x: (point.clientX - rect.left) * scaleX,
      y: (point.clientY - rect.top) * scaleY,
    };
  }

  function start(e) {
    e.preventDefault();
    drawing = true;
    const p = pos(e);
    lastX = p.x;
    lastY = p.y;
  }

  function move(e) {
    if (!drawing) return;
    e.preventDefault();
    const p = pos(e);
    ctx.strokeStyle = colorInput.value;
    ctx.lineWidth = parseInt(sizeInput.value, 10);
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.beginPath();
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
    lastX = p.x;
    lastY = p.y;
  }

  function end(e) {
    if (e) e.preventDefault();
    drawing = false;
  }

  canvas.addEventListener('mousedown', start);
  canvas.addEventListener('mousemove', move);
  window.addEventListener('mouseup', end);
  canvas.addEventListener('touchstart', start, { passive: false });
  canvas.addEventListener('touchmove', move, { passive: false });
  canvas.addEventListener('touchend', end, { passive: false });

  clearBtn.addEventListener('click', () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    paintBackground();
  });

  sendBtn.addEventListener('click', async () => {
    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending...';
    status.textContent = '';
    status.className = 'ar-status';

    const image = canvas.toDataURL('image/png');
    const caption = captionInput.value;

    try {
      const res = await fetch('/api/room-draw', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ image, caption }),
      });
      const data = await res.json();
      if (res.ok && data.ok) {
        status.textContent = 'Sent to Crew (ch:bridge).';
        status.className = 'ar-status ar-status--ok';
      } else {
        status.textContent = 'Error: ' + (data.error || ('HTTP ' + res.status));
        status.className = 'ar-status ar-status--err';
      }
    } catch (err) {
      status.textContent = 'Network error: ' + err.message;
      status.className = 'ar-status ar-status--err';
    }
    sendBtn.disabled = false;
    sendBtn.textContent = 'Send to Crew';
  });
</script>

<style>
  .admin-room {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .ar-header {
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border, #333);
    padding-bottom: 1rem;
  }
  .ar-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted, #777);
    margin-bottom: 0.3rem;
  }
  .ar-header h1 { margin: 0 0 0.5rem; font-size: 1.4rem; }
  .ar-meta { color: var(--color-muted, #999); font-size: 0.82rem; margin: 0 0 0.5rem; }
  .ar-logout {
    background: none; border: 1px solid var(--color-border, #444);
    color: var(--color-muted, #999); padding: 0.3rem 0.8rem;
    border-radius: 4px; font-size: 0.75rem; cursor: pointer;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .ar-surface {
    border: 1px solid var(--color-border, #333);
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    line-height: 0;
  }
  #draw-canvas {
    display: block;
    width: 100%;
    height: auto;
    touch-action: none;
    cursor: crosshair;
  }
  .ar-tools {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 1rem 0;
  }
  .ar-tools label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted, #888);
  }
  .ar-tools input[type="color"] {
    width: 38px; height: 30px; padding: 0; border: none; background: none; cursor: pointer;
  }
  .ar-clear {
    padding: 0.45rem 1rem;
    background: var(--color-surface, #1a1a1a);
    border: 1px solid var(--color-border, #444);
    color: var(--color-text, #eee);
    border-radius: 4px;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .ar-send {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    margin-top: 0.5rem;
  }
  #caption-input {
    flex: 1 1 240px;
    padding: 0.6rem 0.7rem;
    background: var(--color-bg, #111);
    border: 1px solid var(--color-border, #444);
    color: var(--color-text, #eee);
    border-radius: 4px;
    font-size: 0.9rem;
    box-sizing: border-box;
  }
  #send-btn {
    padding: 0.7rem 2rem;
    background: var(--color-text, #eee);
    color: var(--color-bg, #111);
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  #send-btn:hover { opacity: 0.9; }
  #send-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ar-status { font-size: 0.82rem; margin-top: 0.8rem; min-height: 1.2em; }
  .ar-status--ok { color: #66cc66; }
  .ar-status--err { color: #ff6666; }
</style>
