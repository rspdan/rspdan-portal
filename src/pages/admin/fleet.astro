---
// Admin: Fleet Board Editor · PSPT-gated, Phase 1
// Edits crew_seats via /api/fleet-save (GitHub API commit + Vercel redeploy)
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { verifySession } from '../../lib/pspt.js';
import { board, crew_seats } from '../../data/fleet.js';

// Auth gate
const session = verifySession(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/pspt');
}

const stations = Object.entries(crew_seats);
const statusOptions = board.legend.map(l => l.key);
---
<BaseLayout lastUpdated="June 8, 2026" title="Fleet Board Editor">
  <main class="admin-fleet">
    <header class="af-header">
      <div class="af-eyebrow">PSPT ADMIN</div>
      <h1>Fleet Board Editor</h1>
      <p class="af-meta">
        Logged in as <strong>{session.user}</strong> &middot;
        Last updated: {board.updated}
      </p>
      <form method="POST" action="/api/pspt/logout" style="display:inline">
        <button type="submit" class="af-logout">Logout</button>
      </form>
    </header>

    <form id="fleet-form" class="af-form">
      {stations.map(([stationName, stationData]) => (
        <section class="af-section" data-station={stationName}>
          <h2>{stationName}</h2>
          <label>
            <span>Station Status</span>
            <select name={`station_status_${stationName}`}>
              {statusOptions.map(opt => (
                <option value={opt} selected={opt === stationData.station_status}>
                  {opt}
                </option>
              ))}
            </select>
          </label>

          {stationData.seats.map((seat, i) => (
            <div class="af-seat">
              <div class="af-seat-name">{seat.crew}</div>
              <label>
                <span>Status</span>
                <select name={`seat_status_${stationName}_${i}`}>
                  {statusOptions.map(opt => (
                    <option value={opt} selected={opt === seat.status}>
                      {opt}
                    </option>
                  ))}
                </select>
              </label>
              <label>
                <span>Note</span>
                <input type="text" name={`seat_note_${stationName}_${i}`} value={seat.note} />
              </label>
              <input type="hidden" name={`seat_crew_${stationName}_${i}`} value={seat.crew} />
            </div>
          ))}
        </section>
      ))}

      <div class="af-actions">
        <button type="submit" class="af-save" id="save-btn">Save + Deploy</button>
        <div id="save-status" class="af-status"></div>
      </div>
    </form>
  </main>
</BaseLayout>

<script define:vars={{ stations }}>
  // Client-side: collect form data and POST to /api/fleet-save
  document.getElementById('fleet-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn');
    const status = document.getElementById('save-status');
    btn.disabled = true;
    btn.textContent = 'Saving...';
    status.textContent = '';

    const form = e.target;
    const fd = new FormData(form);

    const payload = {
      board_updated: new Date().toLocaleString('en-US', {
        month: '2-digit', day: '2-digit', year: '2-digit',
        hour: '2-digit', minute: '2-digit', hour12: false,
        timeZone: 'America/Los_Angeles'
      }).replace(',', ' ~').replace(/\//g, '') + ' PT',
      seats: {},
    };

    for (const [stationName] of stations) {
      const stationStatus = fd.get(`station_status_${stationName}`);
      const seats = [];
      let i = 0;
      while (fd.has(`seat_crew_${stationName}_${i}`)) {
        seats.push({
          crew: fd.get(`seat_crew_${stationName}_${i}`),
          status: fd.get(`seat_status_${stationName}_${i}`),
          note: fd.get(`seat_note_${stationName}_${i}`),
        });
        i++;
      }
      payload.seats[stationName] = { station_status: stationStatus, seats };
    }

    try {
      const res = await fetch('/api/fleet-save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (data.ok) {
        status.textContent = 'Saved. Vercel will redeploy in ~30s.';
        status.className = 'af-status af-status--ok';
      } else {
        status.textContent = 'Error: ' + (data.error || 'unknown');
        status.className = 'af-status af-status--err';
      }
    } catch (err) {
      status.textContent = 'Network error: ' + err.message;
      status.className = 'af-status af-status--err';
    }
    btn.disabled = false;
    btn.textContent = 'Save + Deploy';
  });
</script>

<style>
  .admin-fleet {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .af-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border, #333);
    padding-bottom: 1rem;
  }
  .af-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted, #777);
    margin-bottom: 0.3rem;
  }
  .af-header h1 { margin: 0 0 0.5rem; font-size: 1.4rem; }
  .af-meta { color: var(--color-muted, #999); font-size: 0.82rem; margin: 0 0 0.5rem; }
  .af-logout {
    background: none; border: 1px solid var(--color-border, #444);
    color: var(--color-muted, #999); padding: 0.3rem 0.8rem;
    border-radius: 4px; font-size: 0.75rem; cursor: pointer;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .af-section {
    background: var(--color-surface, #1a1a1a);
    border: 1px solid var(--color-border, #333);
    border-radius: 6px;
    padding: 1.2rem 1rem;
    margin-bottom: 1rem;
  }
  .af-section h2 {
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.8rem;
    color: var(--color-accent, #4da3ff);
  }
  .af-section label {
    display: block;
    margin-bottom: 0.7rem;
  }
  .af-section label span {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted, #888);
    margin-bottom: 0.2rem;
  }
  .af-section input, .af-section select {
    width: 100%;
    padding: 0.45rem 0.6rem;
    background: var(--color-bg, #111);
    border: 1px solid var(--color-border, #444);
    color: var(--color-text, #eee);
    border-radius: 4px;
    font-size: 0.85rem;
    box-sizing: border-box;
  }
  .af-seat {
    background: var(--color-bg, #111);
    border: 1px solid var(--color-border, #333);
    border-radius: 4px;
    padding: 0.8rem;
    margin-bottom: 0.6rem;
  }
  .af-seat-name {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
    color: var(--color-text, #eee);
  }
  .af-actions {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .af-save {
    padding: 0.7rem 2rem;
    background: var(--color-text, #eee);
    color: var(--color-bg, #111);
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .af-save:hover { opacity: 0.9; }
  .af-save:disabled { opacity: 0.5; cursor: not-allowed; }
  .af-status { font-size: 0.82rem; }
  .af-status--ok { color: #66cc66; }
  .af-status--err { color: #ff6666; }
</style>
