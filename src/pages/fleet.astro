---
// fleet.astro · rspdan.com/fleet · DE-SPRAWLED (one station, one row)
// Per RELAY/SPEC_FleetPageDeSprawl_OneStationTable_NotFourRepeats_CUBE_Trip_060426.md
// El VIS render 060426 · collapses the prior 4x-repeated sections (FLEET ACTUAL cards +
// Rox identity + Hardware + Observation) into ONE details/summary table, one row per Rox,
// every column sourced ONCE from fleet.js. Kept: hold-the-bird philosophy (once), the
// IP-is-a-face principle (once), verified_at staleness model, ONE topology (ASCII sketch).
// Credentials/IPs/MACs stay boxed in fleet_private.js. Verified against preview/fleet-desprawl.html.
// Ported by CUBE Trip 060426 via the text-paste seam (Design surface has no GitHub write).
import BaseLayout from '../layouts/BaseLayout.astro';
import { fleet, board, crew_seats } from '../data/fleet.js';

// Join identity + hardware + seats on name · ONE source per column.
const stations = fleet.rox.map((r) => {
  const h = fleet.hardware[r.name] || {};
  const cs = crew_seats[r.name] || { station_status: 'dark-ready', seats: [] };
  return {
    ...r,
    cpu: h.cpu || 'probe-pending', ram: h.ram || 'probe-pending',
    gpu: h.gpu || 'probe-pending', storage: h.storage || 'probe-pending',
    verified: h.verified_at || 'pending',
    status: cs.station_status, seats: cs.seats,
  };
});
const isPend = (v) => /pending/i.test(String(v));
const legend = board.legend.filter((l) =>
  ['active','standby','off-fleet','dark-ready','off-network','decommissioned','more'].includes(l.key));
---

<BaseLayout lastUpdated="June 8, 2026" title="NEST.03 Fleet · One Station, One Row" description="Fleet as a node system of Rox · one consolidated table: identity, hardware, faces, and live crew seats sourced once from fleet.js. IPs are faces, boxed in fleet_private.js; identity is the Rox. Long-term AND ever-changing.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&display=swap');
    :root{
      --bg:#0c0e14; --card:#13161f; --border:rgba(255,255,255,0.06);
      --muted:#4a5468; --text:#b8bfcc; --head:#e2e8f0;
      --base:#4a7ab5; --rox:#4a9b8e; --obs:#c9a84c; --open:#c94c4c;
      --ip:#7dd3c0; --stamp:#8a93a5; --stale:#c97a4a;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:var(--bg);color:var(--text);font-family:'IBM Plex Mono',monospace;}
    .shell{max-width:1000px;margin:0 auto;padding:3rem 1.5rem 6rem;}
    .eyebrow{font-size:0.5rem;letter-spacing:0.28em;color:var(--obs);text-transform:uppercase;text-align:center;padding:0.5rem 0;border:1px solid rgba(201,168,76,0.25);border-radius:2px;background:linear-gradient(90deg,rgba(201,168,76,0.06),transparent,rgba(201,168,76,0.06));margin-bottom:1.4rem;}
    .titlerow{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;border-bottom:1px solid var(--border);padding-bottom:1.4rem;}
    .title{font-size:2.3rem;color:var(--obs);font-weight:600;letter-spacing:0.06em;}
    .meta{display:grid;grid-template-columns:auto auto;gap:0.15rem 1.2rem;font-size:0.55rem;color:var(--head);text-align:right;}
    .meta span{color:var(--muted);letter-spacing:0.14em;margin-right:0.4rem;}
    .asof{font-size:0.52rem;color:var(--stale);letter-spacing:0.12em;text-transform:uppercase;margin-top:0.9rem;}
    .quote{font-size:0.72rem;color:var(--obs);font-style:italic;line-height:1.7;border-left:2px solid var(--obs);padding:0.5rem 1rem;margin:1.4rem 0 0.7rem;background:linear-gradient(90deg,rgba(201,168,76,0.05),transparent);}
    .principle{background:var(--card);border-left:2px solid var(--base);padding:0.9rem 1.1rem;margin:0 0 1.6rem;border-radius:2px;font-size:0.64rem;line-height:1.7;color:var(--text);}
    .principle strong{color:var(--head);font-weight:500;}.principle em{color:var(--ip);font-style:normal;}
    .legend{display:flex;flex-wrap:wrap;gap:0.7rem;margin:0 0 1.4rem;font-size:0.5rem;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase;}
    .leg{display:inline-flex;align-items:center;gap:0.35rem;}
    .dot{width:7px;height:7px;border-radius:50%;display:inline-block;}
    .s-active{color:var(--rox);}.dot.s-active{background:var(--rox);}
    .s-standby{color:var(--base);}.dot.s-standby{background:var(--base);}
    .s-off-fleet{color:var(--stale);}.dot.s-off-fleet{background:var(--stale);}
    .s-dark-ready{color:var(--base);}.dot.s-dark-ready{background:var(--base);}
    .s-off-network{color:var(--open);}.dot.s-off-network{background:var(--open);}
    .s-decommissioned{color:#5a6072;}.dot.s-decommissioned{background:#5a6072;}
    .s-more{color:#b89a6a;}.dot.s-more{background:#b89a6a;}
    .col-head{display:grid;grid-template-columns:150px 1fr 96px;gap:1rem;padding:0 1rem 0.5rem;font-size:0.48rem;letter-spacing:0.16em;color:var(--muted);text-transform:uppercase;}
    .col-head span:last-child{text-align:right;}
    .tbl{display:flex;flex-direction:column;gap:0.4rem;}
    .st{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--border);border-radius:3px;overflow:hidden;}
    .st[data-st="active"]{border-left-color:var(--rox);}
    .st[data-st="standby"]{border-left-color:var(--base);}
    .st[data-st="off-fleet"]{border-left-color:var(--stale);}
    .st[data-st="dark-ready"]{border-left-color:var(--base);}
    .st[data-st="off-network"]{border-left-color:var(--open);}
    .st[data-st="decommissioned"]{border-left-color:#5a6072;opacity:0.66;}
    summary{display:grid;grid-template-columns:150px 1fr 96px;gap:1rem;align-items:center;padding:0.75rem 1rem;cursor:pointer;list-style:none;}
    summary::-webkit-details-marker{display:none;}
    summary:hover{background:rgba(255,255,255,0.015);}
    .s-name{display:flex;align-items:center;gap:0.5rem;}
    .s-nm{color:var(--head);font-weight:600;font-size:0.78rem;letter-spacing:0.05em;}
    .s-badge{font-size:0.44rem;letter-spacing:0.1em;padding:2px 6px;border-radius:7px;text-transform:uppercase;border:1px solid currentColor;white-space:nowrap;}
    .s-mid .hwos{color:var(--text);font-size:0.64rem;}
    .s-mid .role{color:var(--stamp);font-size:0.56rem;margin-top:0.15rem;line-height:1.4;}
    .mob{justify-self:end;font-size:0.46rem;padding:2px 7px;border-radius:8px;letter-spacing:0.08em;text-transform:uppercase;border:1px solid currentColor;white-space:nowrap;}
    .mob.stationary{color:var(--rox);}.mob.roaming{color:var(--obs);}.mob.full-mobile{color:var(--open);}
    .det{padding:0.2rem 1rem 1rem;border-top:1px dashed rgba(255,255,255,0.05);margin-top:-0.2rem;}
    .det-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.3rem 1.4rem;margin:0.7rem 0;}
    .f{display:grid;grid-template-columns:5.5rem 1fr;gap:0.5rem;font-size:0.6rem;line-height:1.45;}
    .f.wide{grid-column:1/-1;}
    .fk{color:var(--stamp);text-transform:uppercase;letter-spacing:0.1em;font-size:0.5rem;padding-top:0.12rem;}
    .fv{color:var(--text);}.fv.pend{color:var(--obs);font-style:italic;}.fv .boxed{color:var(--muted);font-style:italic;}
    .seats{margin-top:0.6rem;padding-top:0.6rem;border-top:1px dashed rgba(255,255,255,0.05);}
    .seats-h{font-size:0.46rem;letter-spacing:0.18em;color:var(--muted);text-transform:uppercase;margin-bottom:0.4rem;}
    .seat{display:grid;grid-template-columns:auto auto 1fr;gap:0.5rem;align-items:baseline;font-size:0.58rem;margin-bottom:0.3rem;line-height:1.45;}
    .seat-c{color:var(--head);font-weight:500;white-space:nowrap;}
    .seat-s{font-size:0.42rem;letter-spacing:0.08em;padding:1px 5px;border-radius:6px;text-transform:uppercase;border:1px solid currentColor;white-space:nowrap;align-self:start;}
    .seat-n{color:var(--stamp);}
    .seat-idle{font-size:0.56rem;color:var(--muted);font-style:italic;}
    .det-meta{display:flex;gap:1.2rem;flex-wrap:wrap;margin-top:0.6rem;font-size:0.52rem;color:var(--stamp);}
    .det-meta .stale{color:var(--stale);}
    .topo{margin:2.5rem 0 1rem;}
    .topo-h{font-size:0.62rem;color:var(--rox);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:0.8rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border);}
    .ascii-wrap{background:var(--card);border:1px solid var(--border);border-radius:4px;padding:1rem;overflow-x:auto;}
    .ascii-meta{display:flex;justify-content:space-between;gap:0.5rem;flex-wrap:wrap;font-size:0.56rem;color:var(--muted);margin-bottom:0.7rem;padding-bottom:0.55rem;border-bottom:1px dashed var(--border);}
    .ascii{font-family:'SF Mono','Menlo','Consolas',monospace;font-size:0.66rem;line-height:1.25;color:var(--text);white-space:pre;letter-spacing:0;}
    .foot{margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border);font-size:0.55rem;color:var(--muted);line-height:1.8;letter-spacing:0.06em;}
    .foot a{color:var(--rox);text-decoration:none;}
    @media(max-width:680px){
      .col-head,summary{grid-template-columns:1fr auto;}
      .col-head span:nth-child(2){display:none;}
      .s-mid{grid-column:1/-1;}
      .det-grid{grid-template-columns:1fr;}
      .title{font-size:1.7rem;}.meta{text-align:left;}
    }
  </style>

  <div class="shell">
    <div class="eyebrow">⚓ {board.eyebrow} ⚓</div>
    <div class="titlerow">
      <h1 class="title">{board.title}</h1>
      <div class="meta">
        <div><span>STATIONS</span>{fleet.rox.length} ROX</div>
        <div><span>SOURCE</span>fleet.js + fleet_private.js</div>
        <div><span>MODEL</span>NEST.03 · 3P PeaPod</div>
      </div>
    </div>
    <div class="asof">▲ Runtime snapshot as of fleet.js stamp {board.updated} · seat-state is session-scoped, re-verify before treating as live</div>

    <blockquote class="quote">{board.quote}</blockquote>

    <div class="principle">
      <strong>One source, one row.</strong> Station identity is the <em>Rox</em> · name, hardware, OS, location, role, mobility. The IP is a face currently rotated forward; faces change between sessions, so they stay boxed in <em>fleet_private.js</em> and only identity is shown. Every row carries a <em>verified_at</em> stamp; stale rows are marked stale and re-probed, never silently trusted. Expand a station for its hardware, faces, and seated crew.
    </div>

    <div class="legend">
      {legend.map((l) => (
        <span class={"leg s-" + l.key} title={l.desc}><span class={"dot s-" + l.key}></span>{l.label}</span>
      ))}
    </div>

    <div class="col-head"><span>Station</span><span>Hardware · OS / Role</span><span>Mobility</span></div>
    <div class="tbl">
      {stations.map((d) => (
        <details class="st" data-st={d.status}>
          <summary>
            <span class="s-name"><span class={"dot s-" + d.status}></span><span class="s-nm">{d.name}</span><span class={"s-badge s-" + d.status}>{d.status.replace(/-/g, " ").toUpperCase()}</span></span>
            <span class="s-mid"><div class="hwos">{d.hw} · {d.os}</div><div class="role">{d.role}</div></span>
            <span class={"mob " + (d.mobility || "stationary")}>{d.mobility || "stationary"}</span>
          </summary>
          <div class="det">
            <div class="det-grid">
              <div class="f"><span class="fk">cpu</span><span class={"fv" + (isPend(d.cpu) ? " pend" : "")}>{d.cpu}</span></div>
              <div class="f"><span class="fk">ram</span><span class={"fv" + (isPend(d.ram) ? " pend" : "")}>{d.ram}</span></div>
              <div class="f"><span class="fk">gpu</span><span class={"fv" + (isPend(d.gpu) ? " pend" : "")}>{d.gpu}</span></div>
              <div class="f"><span class="fk">storage</span><span class={"fv" + (isPend(d.storage) ? " pend" : "")}>{d.storage}</span></div>
              <div class="f wide"><span class="fk">location</span><span class="fv">{d.loc}</span></div>
              <div class="f wide"><span class="fk">faces</span><span class="fv">{d.faces} <span class="boxed">· IPs boxed</span></span></div>
            </div>
            <div class="seats">
              <div class="seats-h">Crew seated (as of {board.updated})</div>
              {d.seats.length > 0 ? d.seats.map((s) => (
                <div class="seat"><span class="seat-c">{s.crew}</span><span class={"seat-s s-" + s.status}>{s.status.replace(/-/g, " ").toUpperCase()}</span><span class="seat-n">{s.note}</span></div>
              )) : <div class="seat-idle">No crew seated · station idle</div>}
            </div>
            <div class="det-meta"><span class={/stale|pending/i.test(d.verified) ? "stale" : ""}>verified {d.verified}</span><span>probe: (boxed)</span></div>
          </div>
        </details>
      ))}
    </div>

    <div class="topo">
      <div class="topo-h">Living Map · canonical reference</div>
      <div class="ascii-wrap">
        <div class="ascii-meta">
          <span>Hand-lettered sketch · NEST.01_NOTES_041426 (Dan's Illustrator framework)</span>
          <span>Switch ports shown · IPs / SSIDs / shares boxed</span>
        </div>
        <pre is:raw class="ascii">    NORTH WINDOW   ·   external signal this way  ───▶

    UNIX  ZONE                                  WINDOWS  ZONE
    ─────────────────────────                   ─────────────────────────
    UNIX DESK 2                                 WINDOWS DESK 1
      DPSL    5PSW p4    ★                         ODT     8PSW p3    ★
      DPSR    5PSW p5    ★                         (+ Wacom · Westi · BAS)
      (iMac twins · Universal Control)
                                                WINDOWS DESK 2
    UNIX DESK 1                                   STN2    8PSW p5    ◯   (off-fleet at OHC)
      TRP0    5PSW p3    ◯                         CUBE    8PSW p8    ★   (+ ALFA USB ●)
      GOG1    5PSW p2    ✕   (decommissioned)
      (multi-home: Public + VZW + copper)

    CENTER
      PIRALUS  ·  Netgear R7900 backbone  ·  DHCP (boxed)  ·  Fleet WiFi (boxed)
      STN1    8PSW p6    ◯   (via Dell K16A hub)
      ACHE    by window  ★★  (Galaxy S10 · always with Dan)

    LEGEND   ★ stationary    ◯ roaming    ★★ full-mobile (Dan)    ✕ decommissioned    ● accessory
    LINKS    5PSW ──▶ PIRALUS p1 · 8PSW ──▶ PIRALUS p2 · DPSL ◀─ Universal Control ─▶ DPSR</pre>
      </div>
    </div>

    <div class="foot">
      Related: <a href="/gulls">/gulls</a> · <a href="/logs">/logs</a> · <a href="/nest-pi">/nest-pi</a> · <a href="/nest">/nest</a><br/>
      Source: src/data/fleet.js (public) · src/data/fleet_private.js (boxed, gitignored) · FLEET/INVENTORY.md · RELAY/STANDARD_RULE_FleetIPsObservedNotDefining_Trip_041626.md
    </div>
  </div>
</BaseLayout>
