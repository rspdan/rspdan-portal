---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fleet } from '../data/fleet.js';
---

<BaseLayout title="NEST.01 Fleet" description="Fleet as a node system of Rox — living record of identity, observation, open faces">
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&display=swap');
:root{
  --bg:#0c0e14;
  --card:#13161f;
  --border:rgba(255,255,255,0.06);
  --muted:#4a5468;
  --text:#b8bfcc;
  --head:#e2e8f0;
  --base:#4a7ab5;
  --rox:#4a9b8e;
  --obs:#c9a84c;
  --open:#c94c4c;
  --ip:#7dd3c0;
  --stamp:#8a93a5;
  --stale:#c97a4a;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'IBM Plex Mono',monospace;}
.shell{max-width:1100px;margin:0 auto;padding:3rem 1.5rem 8rem;}

.hdr{border-bottom:1px solid var(--border);padding-bottom:1.5rem;margin-bottom:2rem;}
.eyebrow{font-size:0.52rem;letter-spacing:0.32em;color:var(--muted);text-transform:uppercase;margin-bottom:0.4rem;}
.title{font-size:1.5rem;color:var(--head);font-weight:300;letter-spacing:0.04em;}
.sub{font-size:0.58rem;color:var(--muted);margin-top:0.4rem;letter-spacing:0.1em;line-height:1.6;}

.live-banner{background:linear-gradient(90deg,rgba(74,155,142,0.08),transparent);border-left:3px solid var(--rox);padding:0.9rem 1.1rem;margin:1.2rem 0 0;border-radius:2px;}
.live-banner .row{display:flex;flex-wrap:wrap;gap:1.2rem;align-items:baseline;font-size:0.65rem;}
.live-banner .lbl{color:var(--muted);text-transform:uppercase;letter-spacing:0.18em;font-size:0.5rem;}
.live-banner .val{color:var(--head);font-weight:500;}
.live-banner .note{font-size:0.58rem;color:var(--stamp);margin-top:0.5rem;font-style:italic;}
.live-banner .edit{font-size:0.55rem;color:var(--rox);margin-top:0.35rem;font-family:inherit;}
.live-banner code{background:rgba(255,255,255,0.05);padding:1px 5px;border-radius:2px;color:var(--ip);font-size:0.85em;}

.principle{background:var(--card);border-left:2px solid var(--base);padding:1rem 1.2rem;margin:2rem 0 1.5rem;border-radius:2px;font-size:0.68rem;line-height:1.7;color:var(--text);}
.principle strong{color:var(--head);font-weight:500;}

section{margin:2.5rem 0;}
.sec-head{display:flex;align-items:baseline;gap:0.8rem;margin-bottom:0.9rem;padding-bottom:0.5rem;border-bottom:1px solid var(--border);}
.sec-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sec-dot.base{background:var(--base);}
.sec-dot.rox{background:var(--rox);}
.sec-dot.obs{background:var(--obs);}
.sec-dot.open{background:var(--open);}
.sec-title{font-size:0.72rem;color:var(--head);letter-spacing:0.22em;text-transform:uppercase;font-weight:500;}
.sec-count{font-size:0.55rem;color:var(--muted);letter-spacing:0.16em;margin-left:auto;}

.row-block{background:var(--card);border:1px solid var(--border);border-radius:3px;padding:0.85rem 1rem;margin-bottom:0.55rem;font-size:0.64rem;line-height:1.55;}
.row-block:hover{border-color:rgba(255,255,255,0.1);}

.row-top{display:flex;gap:1rem;align-items:baseline;flex-wrap:wrap;margin-bottom:0.3rem;}
.row-name{color:var(--head);font-weight:500;min-width:110px;font-size:0.7rem;}
.row-ip{font-weight:500;color:var(--ip);font-size:0.82rem;letter-spacing:0.03em;padding:2px 8px;background:rgba(125,211,192,0.08);border-radius:2px;font-family:'IBM Plex Mono',monospace;}
.row-ip.empty{color:var(--muted);background:rgba(255,255,255,0.02);font-weight:300;font-size:0.68rem;}
.row-face{color:var(--text);font-size:0.62rem;}
.row-detail{color:var(--stamp);font-size:0.6rem;margin-top:0.2rem;line-height:1.5;}
.row-meta{display:flex;gap:1.2rem;align-items:center;flex-wrap:wrap;margin-top:0.45rem;padding-top:0.4rem;border-top:1px dashed rgba(255,255,255,0.04);font-size:0.54rem;color:var(--muted);}
.row-meta .stamp{color:var(--stamp);font-weight:500;letter-spacing:0.06em;}
.row-meta .stamp.stale{color:var(--stale);}
.row-meta .probe{font-style:italic;}

.baseplate-row{display:grid;grid-template-columns:140px 1fr 1fr;gap:1rem;align-items:baseline;}
.baseplate-role{color:var(--head);font-weight:500;font-size:0.68rem;}
.baseplate-hw{color:var(--text);font-size:0.6rem;}
.baseplate-func{color:var(--text);font-size:0.6rem;}
.baseplate-note{color:var(--stamp);font-size:0.58rem;margin-top:0.25rem;line-height:1.5;}

.rox-row{display:grid;grid-template-columns:90px 1fr;gap:1rem;align-items:baseline;}
.rox-name{color:var(--head);font-weight:500;font-size:0.72rem;letter-spacing:0.05em;}
.rox-body{}
.rox-hw{color:var(--text);font-size:0.62rem;}
.rox-meta-l2{color:var(--stamp);font-size:0.58rem;margin-top:0.2rem;}
.rox-faces{color:var(--text);font-size:0.58rem;margin-top:0.3rem;line-height:1.55;padding-top:0.3rem;border-top:1px dashed rgba(255,255,255,0.04);}

.open-row{display:grid;grid-template-columns:140px 1fr;gap:1rem;}
.open-rox{color:var(--open);font-weight:500;font-size:0.66rem;}
.open-face{color:var(--head);font-size:0.62rem;margin-bottom:0.3rem;}
.open-issue{color:var(--text);font-size:0.6rem;line-height:1.55;margin-bottom:0.35rem;}
.open-action{color:var(--stamp);font-size:0.58rem;font-style:italic;line-height:1.55;}
.open-status{font-size:0.52rem;color:var(--obs);letter-spacing:0.14em;text-transform:uppercase;margin-top:0.4rem;}

.foot{margin-top:4rem;padding-top:1.5rem;border-top:1px solid var(--border);font-size:0.55rem;color:var(--muted);line-height:1.7;letter-spacing:0.08em;}
.foot a{color:var(--rox);text-decoration:none;}
.foot a:hover{color:var(--head);}
</style>

<div class="shell">
  <div class="hdr">
    <div class="eyebrow">NEST.01 · Fleet Map</div>
    <div class="title">Fleet as a node system of Rox</div>
    <div class="sub">A living record. Identity is the cube; IPs are faces currently rotated forward. Every statement names Rox · face · probe · time.</div>

    <div class="live-banner">
      <div class="row">
        <span><span class="lbl">Updated</span> <span class="val">{fleet.updated}</span></span>
        <span><span class="lbl">By</span> <span class="val">{fleet.updated_by}</span></span>
      </div>
      <div class="edit">Editable source: <code>src/data/fleet.js</code> — edit the file directly, push, portal rebuilds.</div>
      <div class="note">{fleet.instructions}</div>
    </div>
  </div>

  <div class="principle">
    <strong>Principle.</strong> Station identity is the Rox — name, hardware, OS, location, switch port, role. The IP is a face currently rotated forward. Faces change between sessions and cannot be used to identify the station. Every observation on this page is session-scoped and carries a <em>verified_at</em> timestamp. When a row goes stale, it gets marked stale and re-probed, not silently trusted. Full rule: <em>RELAY/STANDARD_RULE_FleetIPsObservedNotDefining_Trip_041626.md</em>
  </div>

  <section>
    <div class="sec-head">
      <div class="sec-dot base"></div>
      <div class="sec-title">Baseplate — persistent identity</div>
      <div class="sec-count">{fleet.baseplate.length} items</div>
    </div>
    {fleet.baseplate.map((b) => (
      <div class="row-block">
        <div class="baseplate-row">
          <div class="baseplate-role">{b.role}</div>
          <div>
            <div class="baseplate-hw">{b.hardware}</div>
            <div class="baseplate-note">{b.loc}</div>
          </div>
          <div>
            <div class="baseplate-func">{b.func}</div>
            <div class="baseplate-note">{b.note}</div>
          </div>
        </div>
        <div class="row-meta">
          <span class="stamp">verified {b.verified_at}</span>
          <span class="probe">via {b.probe}</span>
        </div>
      </div>
    ))}
  </section>

  <section>
    <div class="sec-head">
      <div class="sec-dot rox"></div>
      <div class="sec-title">Rox — station identity</div>
      <div class="sec-count">{fleet.rox.length} stations</div>
    </div>
    {fleet.rox.map((r) => (
      <div class="row-block">
        <div class="rox-row">
          <div class="rox-name">{r.name}</div>
          <div class="rox-body">
            <div class="rox-hw">{r.hw} · {r.os}</div>
            <div class="rox-meta-l2">{r.loc} — {r.role}</div>
            <div class="rox-faces">Faces: {r.faces}</div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <section>
    <div class="sec-head">
      <div class="sec-dot obs"></div>
      <div class="sec-title">Observation — current face rotation</div>
      <div class="sec-count">{fleet.observation.length} rows</div>
    </div>
    {fleet.observation.map((o) => (
      <div class="row-block">
        <div class="row-top">
          <span class="row-name">{o.rox}</span>
          <span class={"row-ip " + (o.ip.includes('(') ? 'empty' : '')}>{o.ip}</span>
          <span class="row-face">{o.face}</span>
        </div>
        <div class="row-detail">{o.detail}</div>
        <div class="row-meta">
          <span class={"stamp " + (o.verified_at === 'stale' ? 'stale' : '')}>verified {o.verified_at}</span>
          <span class="probe">via {o.probe}</span>
        </div>
      </div>
    ))}
  </section>

  <section>
    <div class="sec-head">
      <div class="sec-dot open"></div>
      <div class="sec-title">Open faces — unresolved, under observation</div>
      <div class="sec-count">{fleet.open_faces.length} items</div>
    </div>
    {fleet.open_faces.map((f) => (
      <div class="row-block">
        <div class="open-row">
          <div class="open-rox">{f.rox}</div>
          <div>
            <div class="open-face">{f.face}</div>
            <div class="open-issue">{f.issue}</div>
            <div class="open-action">→ {f.action}</div>
            {f.status && <div class="open-status">{f.status}</div>}
          </div>
        </div>
        <div class="row-meta">
          <span class="stamp">verified {f.verified_at}</span>
        </div>
      </div>
    ))}
  </section>

  <div class="foot">
    Related: <a href="/gulls">/gulls</a> · <a href="/logs">/logs</a> · <a href="/nest-pi">/nest-pi</a><br/>
    Source docs: RELAY/STANDARD_RULE_FleetIPsObservedNotDefining_Trip_041626.md · RELAY/TRIP_ROX_ABSORPTION_FleetAsNodeSystem_041626.md · FLEET/INVENTORY.md · NEST.01_NOTES_041426_1.png
  </div>
</div>
</BaseLayout>
