---
// PSPT Login · the gate. No public registration. Crew-only.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { verifySession } from '../lib/pspt.js';

const nextRaw = Astro.url.searchParams.get('next') || '/admin/fleet';
const next = nextRaw.startsWith('/') && !nextRaw.startsWith('//') ? nextRaw : '/admin/fleet';

// If already logged in, redirect to the requested private surface.
const session = verifySession(Astro.request.headers.get('cookie'));
if (session) {
  return Astro.redirect(next);
}

const error = Astro.url.searchParams.get('error');
const errorMsg = {
  missing: 'Username and password required.',
  invalid: 'Invalid credentials.',
  config:  'Auth not configured. Contact Dan.',
}[error] || '';
---
<BaseLayout lastUpdated="June 4, 2026" title="PSPT">
  <main class="pspt-gate">
    <div class="pspt-box">
      <div class="pspt-eyebrow">HEIRCOR OP</div>
      <h1>PSPT</h1>
      <p class="pspt-desc">Crew access. No public registration.</p>

      {errorMsg && <div class="pspt-error">{errorMsg}</div>}

      <form method="POST" action="/api/pspt/login" class="pspt-form">
        <input type="hidden" name="next" value={next} />
        <label>
          <span>Username</span>
          <input type="text" name="username" autocomplete="username" required />
        </label>
        <label>
          <span>Password</span>
          <input type="password" name="password" autocomplete="current-password" required />
        </label>
        <button type="submit">Enter</button>
      </form>
    </div>
  </main>
</BaseLayout>

<style>
  .pspt-gate {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 2rem;
  }
  .pspt-box {
    max-width: 360px;
    width: 100%;
    background: var(--color-surface, #1a1a1a);
    border: 1px solid var(--color-border, #333);
    padding: 2.5rem 2rem;
    border-radius: 8px;
  }
  .pspt-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted, #777);
    margin-bottom: 0.5rem;
  }
  .pspt-box h1 {
    font-size: 1.6rem;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
  }
  .pspt-desc {
    color: var(--color-muted, #777);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }
  .pspt-error {
    background: #3a1111;
    border: 1px solid #662222;
    color: #ff6666;
    padding: 0.6rem 0.8rem;
    border-radius: 4px;
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }
  .pspt-form label {
    display: block;
    margin-bottom: 1rem;
  }
  .pspt-form label span {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted, #999);
    margin-bottom: 0.3rem;
  }
  .pspt-form input {
    width: 100%;
    padding: 0.55rem 0.7rem;
    background: var(--color-bg, #111);
    border: 1px solid var(--color-border, #444);
    color: var(--color-text, #eee);
    border-radius: 4px;
    font-size: 0.9rem;
    box-sizing: border-box;
  }
  .pspt-form input:focus {
    outline: none;
    border-color: var(--color-accent, #4da3ff);
  }
  .pspt-form button {
    width: 100%;
    padding: 0.65rem;
    background: var(--color-text, #eee);
    color: var(--color-bg, #111);
    border: none;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    margin-top: 0.5rem;
  }
  .pspt-form button:hover {
    opacity: 0.9;
  }
</style>
