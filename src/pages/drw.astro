---
// DRW: Operating Room drawing workbench. PSPT-gated. The ConsOlo (Dan's name,
// 070226, for the Nest Console this version: Console + Olo).
// Layer model (0/1/2 nesting · Dan-direct 062326): 0 BKG, 1 CLR, 2 LNS, with
// decimal children (CLR.01, CLR.02 ...). Every layer has its own canvas and
// opacity. Save persists the layered scene (nothing gets lost) AND a flat
// composite PNG (Chad's existing /api/drw proof chain stays intact).
//
// ConsOlo UI pass (Dan-direct 070226 "apply the VISdev look? Fix the text
// tool? Add ability to rename layers ... L&L (Launch & Load) << Should
// function as a general 'open anything and it works' + nothing gets lost +
// Make It Visible"):
// - Chrome skinned in the VISdev.01 LITE BRITE register (the delivered El VIS
//   kit, VISdev-Kit-LiteBrite.html: "real-artificial · 1996 chrome, 2026
//   engine". Black pegboard #08080a with peg-hole texture, VT323 CRT type +
//   Silkscreen pixel labels, OLO #01FFCD as THE glow, CRT scanline/vignette
//   overlays). Dan-direct 070226: "Take the old shit and make it use the
//   VISdev.01 kit". The skin WRAPS the workbench; the Usic colors +
//   non-colors stay the palette, rendered as glowing pegs.
// - Text tool: inline on-canvas editor (was a blocking window.prompt).
// - Layers: rename affordance (double-click a layer name); the 0/1/2 +
//   decimal-children identity model is untouched, a label rides along.
// - L&L (Launch & Load): the LOAD GAME seed generalized. One entry opens a
//   game cartridge, an image (lands on a new Color child layer), a video
//   (plays on the console screen; EJECT returns to DRW, no reload), or a DRW
//   draft (.drw.json; current work is backed up first, nothing gets lost).
//   EXPORT DRAFT writes the file L&L can open back. Unknown types get an
//   honest status line; the handler registry extends.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { verifySession } from '../lib/pspt.js';

const session = verifySession(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect('/pspt?next=/drw');
}

// The 14 colors of Usic (12 Circle-of-5ths keys + Storm Violet + OLO) PLUS
// the non-colors (black / white / gray ramp). Dan-direct 070226: "the Usic
// colors literally ARE MY COLORS. FUCKING USE THEM. DO NOT FORGET THE
// NON-COLORS, B&W, GRAY, ETC." Key hexes instrument-confirmed from
// src/pages/usic.astro (the live source-of-truth); the non-colors are the
// true non-colors (not a claimed Dan-specific brand hex).
const USIC_COLORS = [
  { key: 'C',  name: 'Red',          hex: '#E53327' },
  { key: 'G',  name: 'Green',        hex: '#31A048' },
  { key: 'D',  name: 'Pink',         hex: '#D43259' },
  { key: 'A',  name: 'Yellow',       hex: '#ECD31B' },
  { key: 'E',  name: 'Purple',       hex: '#9376B3' },
  { key: 'B',  name: 'Orange',       hex: '#F09021' },
  { key: 'F',  name: 'Blue',         hex: '#45B7C8' },
  { key: 'F#', name: 'Sky',          hex: '#80CEE0' },
  { key: 'C#', name: 'Brick',        hex: '#9B4F3A' },
  { key: 'G#', name: 'Lime',         hex: '#84C44E' },
  { key: 'D#', name: 'Magenta',      hex: '#B5338A' },
  { key: 'A#', name: 'Tan',          hex: '#D4B483' },
  { key: '·',  name: 'Storm Violet', hex: '#7B2D8E' },
  { key: '·',  name: 'OLO',          hex: '#01FFCD' },
  // Non-colors (Dan-direct: do not forget these).
  { key: '·',  name: 'Black',        hex: '#000000' },
  { key: '·',  name: 'Gray 3',       hex: '#404040' },
  { key: '·',  name: 'Gray 2',       hex: '#808080' },
  { key: '·',  name: 'Gray 1',       hex: '#BFBFBF' },
  { key: '·',  name: 'White',        hex: '#FFFFFF' },
];
---
<BaseLayout lastUpdated="July 2, 2026" title="DRW">
  <!-- LITE BRITE kit fonts (the kit's exact Google Fonts import): VT323 CRT
       terminal + Silkscreen pixel labels. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=VT323&family=Silkscreen:wght@400;700&display=swap" rel="stylesheet" />
  <main class="drw-shell">
    <section class="drw-window" aria-label="DRW drawing workbench">
      <header class="drw-titlebar">
        <div>
          <span class="drw-title">DRW.EXE</span>
          <span class="drw-path">rspdan.com/drw</span>
          <span class="drw-tag">THE CONSOLO</span>
        </div>
        <form method="POST" action="/api/pspt/logout">
          <button type="submit" class="drw-window-btn">LOGOUT</button>
        </form>
      </header>

      <div class="drw-menubar" aria-label="Workbench menu">
        <span>FILE</span>
        <span>EDIT</span>
        <span>VIEW</span>
        <span>ROOM</span>
        <button type="button" id="lnl-btn" class="drw-menu-action drw-lnl" title="L&L · Launch & Load: open anything and it works. Opens a game cartridge (.gba/.gb/.gbc/.zip), an image (new layer), a video (.mp4/.webm/.mov), or a DRW draft (.drw.json)">L&amp;L</button>
        <button type="button" id="export-draft-btn" class="drw-menu-action" title="Save the current working draft as a .drw.json file. L&L opens it back; nothing gets lost">EXPORT DRAFT</button>
        <button type="button" id="eject-game-btn" class="drw-menu-action" hidden title="Eject the cartridge and return to DRW">EJECT</button>
        <span class="drw-user">OPERATOR: {session.user}</span>
      </div>

      <div class="drw-body">
        <div class="drw-left">
          <div class="drw-toolbar" aria-label="Drawing controls">
            <button type="button" class="tool is-active" data-tool="pen">PEN</button>
            <button type="button" class="tool" data-tool="erase">ERASE</button>
            <button type="button" class="tool" data-tool="text">TEXT</button>
            <button type="button" id="undo-btn" class="tool">UNDO</button>
            <button type="button" id="redo-btn" class="tool">REDO</button>
            <button type="button" id="clear-btn" class="tool">CLEAR LAYER</button>
            <label class="drw-control">
              <span>WIDTH</span>
              <input type="range" id="size-input" min="1" max="42" value="5" />
            </label>
          </div>

          <div class="drw-swatches" aria-label="Usic colors">
            {USIC_COLORS.map((c, i) => (
              <button
                type="button"
                class={`swatch${i === 0 ? ' is-active' : ''}`}
                data-color={c.hex}
                style={`--swatch:${c.hex}`}
                title={`${c.key !== '·' ? c.key + ' · ' : ''}${c.name}`}
              ><span>{c.name}</span></button>
            ))}
          </div>

          <div class="canvas-frame">
            <canvas id="draw-canvas" width="960" height="640"></canvas>
            <textarea id="text-editor" class="text-editor" hidden rows="1"
              spellcheck="false" aria-label="Type text, Enter places it, Escape cancels"></textarea>
          </div>

          <!-- NEST CONSOLE game mode (additive · Dan-direct 070226): DRW is the
               default screen; LOAD GAME boots a cartridge in-browser. Hidden
               until a cartridge is loaded; DRW markup/state stays intact. -->
          <div class="game-frame" id="game-frame" hidden aria-label="Game console">
            <div class="game-cartridge" id="game-cartridge">
              <div class="panel-title">CARTRIDGE</div>
              <div id="cartridge-name" class="cartridge-name">NO CARTRIDGE</div>
              <div class="cartridge-actions">
                <button type="button" id="sav-btn" class="tool">INSERT .SAV (OPTIONAL)</button>
                <button type="button" id="power-btn" class="tool">POWER ON</button>
              </div>
              <div class="cartridge-note">
                The cartridge runs in this browser only; nothing is uploaded.
                Battery saves round-trip via the emulator menu's EXPORT SAVE /
                IMPORT SAVE (same .sav format as MyBoy / mGBA).
              </div>
            </div>
            <div id="ejs-mount-wrap"><div id="ejs-mount"></div></div>
          </div>
          <!-- NEST CONSOLE video mode (additive · registry extension 070326):
               L&L opens a video the same way it opens a cartridge; the video
               plays on the console screen. Hidden until a video is loaded;
               DRW markup/state stays intact. EJECT returns to DRW without a
               reload (nothing is lost; the working draft never left). -->
          <div class="video-frame" id="video-frame" hidden aria-label="Video player">
            <div class="video-reel">
              <div class="panel-title">VIDEO</div>
              <div id="video-name" class="cartridge-name">NO VIDEO</div>
              <div class="cartridge-note">
                The video plays in this browser only; nothing is uploaded.
                EJECT returns to DRW; the working draft is untouched.
              </div>
            </div>
            <video id="video-player" controls playsinline preload="metadata"></video>
          </div>
          <!-- L&L (Launch & Load) takes ANY file; the dispatch below routes it
               to the handler that knows it (game / image / draft) and says so
               honestly when a type is not wired yet. -->
          <input type="file" id="lnl-input" hidden />
          <input type="file" id="sav-input" accept=".sav,.srm" hidden />

          <div class="layers-panel" aria-label="Layers">
            <div class="panel-title layers-title">
              <span>LAYERS</span>
            </div>
            <div id="layer-list" class="layer-list"></div>
          </div>

          <div class="drw-submit">
            <label for="caption-input">LABEL</label>
            <input type="text" id="caption-input" maxlength="500" autocomplete="off" />
            <button type="button" id="save-btn">SAVE + RELAY</button>
          </div>
        </div>

        <aside class="drw-right" aria-label="Saved drawings">
          <div class="panel-title">RECENT DRW</div>
          <div id="draw-list" class="draw-list">
            <div class="draw-empty">LOADING...</div>
          </div>
        </aside>
      </div>

      <footer class="drw-status" id="status-line">READY</footer>
    </section>
  </main>
</BaseLayout>

<script>
  const W = 960;
  const H = 640;
  const DRAFT_KEY = 'drw:draft:v1';
  // L&L nothing-gets-lost: before a draft-file replaces the working scene,
  // the current scene is stashed under a timestamped backup key (last 3 kept).
  const BACKUP_PREFIX = 'drw:draft:backup:';

  const view = document.getElementById('draw-canvas');
  const vctx = view.getContext('2d');
  const textEditor = document.getElementById('text-editor');
  const exportDraftBtn = document.getElementById('export-draft-btn');
  const sizeInput = document.getElementById('size-input');
  const clearBtn = document.getElementById('clear-btn');
  const undoBtn = document.getElementById('undo-btn');
  const redoBtn = document.getElementById('redo-btn');
  const saveBtn = document.getElementById('save-btn');
  const captionInput = document.getElementById('caption-input');
  const statusLine = document.getElementById('status-line');
  const drawList = document.getElementById('draw-list');
  const layerListEl = document.getElementById('layer-list');
  const toolButtons = Array.from(document.querySelectorAll('.tool[data-tool]'));
  const swatches = Array.from(document.querySelectorAll('.swatch'));
  const dimensionInputs = Array.from(document.querySelectorAll('input[name="dimension-tags"]'));
  const confidenceInput = document.getElementById('confidence-input');
  const sourceInput = document.getElementById('source-input');
  const resolverInput = document.getElementById('resolver-input');

  let drawing = false;
  let lastX = 0;
  let lastY = 0;
  let tool = 'pen';
  let ink = swatches[0] ? swatches[0].dataset.color : '#E53327';

  // Undo/redo (B-side, ported from Chad's main onto the layer model): a linear
  // history of per-layer before-snapshots. Snapshots the layer touched, not the
  // flat canvas, so undo/redo composes with layers + opacity.
  let history = [];
  let redoStack = [];

  // ---- Layer model -------------------------------------------------------
  // Each layer: { major (0/1/2), minor (0=root), id, name, opacity, visible,
  //   canvas (offscreen), ctx }. Composite + panel order follow the layers
  //   array (first element = back of the stack). The operator reorders freely
  //   with the up/down controls; major/minor are identity + name only, never
  //   a fixed order-lock. The saved array order is what persists.
  const ROOT_NAMES = { 0: 'Background', 1: 'Color', 2: 'Lines' };
  let layers = [];
  let activeId = null;

  function pad2(n) { return String(n).padStart(2, '0'); }

  function newCanvas() {
    const c = document.createElement('canvas');
    c.width = W;
    c.height = H;
    return c;
  }

  function makeLayer(major, minor, opacity, visible, label) {
    const canvas = newCanvas();
    const id = minor === 0 ? String(major) : `${major}.${pad2(minor)}`;
    const name = minor === 0 ? ROOT_NAMES[major] : `${ROOT_NAMES[major]}.${pad2(minor)}`;
    // label = operator-given display name (rename affordance, Dan-direct
    // 070226). Identity (major/minor/id/name) is the 0/1/2 + decimal-children
    // model and never changes; the label rides along and persists.
    return { major, minor, id, name, label: label || '', opacity, visible, canvas, ctx: canvas.getContext('2d') };
  }

  function displayName(layer) {
    return layer.label || layer.name;
  }

  // Move a layer one step through the stack. dir +1 = toward the front (up),
  // dir -1 = toward the back (down). Any layer moves, including the roots;
  // the operator is in control of the order, nothing is pinned.
  function moveLayer(id, dir) {
    const i = layers.findIndex((l) => l.id === id);
    const j = i + dir;
    if (i < 0 || j < 0 || j >= layers.length) return;
    const moved = layers[i];
    layers[i] = layers[j];
    layers[j] = moved;
    renderLayers();
    composite();
    saveDraft();
    setStatus(`MOVED ${displayName(moved)}`);
  }

  function activeLayer() {
    return layers.find((l) => l.id === activeId) || null;
  }

  function defaultLayers() {
    layers = [
      makeLayer(0, 0, 1, true), // BKG
      makeLayer(1, 0, 1, true), // CLR
      makeLayer(2, 0, 1, true), // LNS
    ];
    // BKG starts as white paper.
    const bkg = layers[0].ctx;
    bkg.fillStyle = '#ffffff';
    bkg.fillRect(0, 0, W, H);
    activeId = '2'; // draw lines by default
  }

  function nextMinor(major) {
    const minors = layers.filter((l) => l.major === major && l.minor > 0).map((l) => l.minor);
    return (minors.length ? Math.max(...minors) : 0) + 1;
  }

  function addChild(major, label) {
    const layer = makeLayer(major, nextMinor(major), 1, true, label);
    layers.push(layer); // new sub-layer lands on top of the stack; reorder freely
    activeId = layer.id;
    renderLayers();
    composite();
    saveDraft();
    setStatus(`ADDED ${displayName(layer)}`);
    return layer;
  }

  function deleteLayer(id) {
    const layer = layers.find((l) => l.id === id);
    if (!layer || layer.minor === 0) return; // roots are permanent
    layers = layers.filter((l) => l.id !== id);
    if (activeId === id) activeId = '2';
    renderLayers();
    composite();
    saveDraft();
    setStatus(`DELETED ${displayName(layer)}`);
  }

  // ---- Compositing -------------------------------------------------------
  function composite() {
    vctx.clearRect(0, 0, W, H);
    for (const layer of layers) {
      if (!layer.visible) continue;
      vctx.globalAlpha = layer.opacity;
      vctx.drawImage(layer.canvas, 0, 0);
    }
    vctx.globalAlpha = 1;
  }

  // ---- Undo / redo (per-layer before-snapshots) --------------------------
  function snapshotBefore() {
    const layer = activeLayer();
    if (!layer) return;
    history.push({ id: layer.id, png: layer.canvas.toDataURL('image/png') });
    if (history.length > 40) history.shift();
    redoStack = [];
  }

  function restoreLayerSnapshot(snap, opposite) {
    const layer = layers.find((l) => l.id === snap.id);
    if (!layer) return;
    opposite.push({ id: snap.id, png: layer.canvas.toDataURL('image/png') });
    const img = new Image();
    img.onload = () => {
      layer.ctx.clearRect(0, 0, W, H);
      layer.ctx.drawImage(img, 0, 0);
      composite();
    };
    img.src = snap.png;
    activeId = snap.id;
    renderLayers();
    saveDraft();
  }

  function undo() {
    const snap = history.pop();
    if (!snap) { setStatus('NOTHING TO UNDO'); return; }
    restoreLayerSnapshot(snap, redoStack);
    setStatus('UNDO');
  }

  function redo() {
    const snap = redoStack.pop();
    if (!snap) { setStatus('NOTHING TO REDO'); return; }
    restoreLayerSnapshot(snap, history);
    setStatus('REDO');
  }

  function setStatus(text) {
    statusLine.textContent = text;
  }

  function escapeHtml(value) {
    return (value || '').toString().replace(/[<>&"]/g, (c) => ({ '<':'&lt;', '>':'&gt;', '&':'&amp;', '"':'&quot;' }[c]));
  }

  function safeHttpUrl(value) {
    try {
      const url = new URL(value);
      return url.protocol === 'https:' || url.protocol === 'http:' ? escapeHtml(url.href) : '';
    } catch {
      return '';
    }
  }

  // ---- Layer panel UI ----------------------------------------------------
  function renderLayers() {
    layerListEl.innerHTML = '';
    // Render top-of-stack at the top of the panel (standard editor order).
    for (let idx = layers.length - 1; idx >= 0; idx--) {
      const layer = layers[idx];
      const row = document.createElement('div');
      row.className = `layer-row${layer.id === activeId ? ' is-active' : ''}${layer.minor > 0 ? ' is-child' : ''}`;

      const vis = document.createElement('input');
      vis.type = 'checkbox';
      vis.checked = layer.visible;
      vis.className = 'layer-vis';
      vis.title = 'Show / hide layer';
      vis.addEventListener('change', () => {
        layer.visible = vis.checked;
        composite();
        saveDraft();
      });

      const name = document.createElement('button');
      name.type = 'button';
      name.className = 'layer-name';
      name.textContent = displayName(layer);
      name.title = `${layer.id} · ${layer.name} · double-click to rename`;
      // Single click activates, double-click renames. The activation re-render
      // is DEFERRED past the double-click window; re-rendering on the first
      // click would destroy this button before the dblclick could land.
      let clickTimer = null;
      name.addEventListener('click', () => {
        clearTimeout(clickTimer);
        clickTimer = setTimeout(() => {
          activeId = layer.id;
          renderLayers();
          setStatus(`ACTIVE ${displayName(layer)}`);
        }, 250);
      });
      name.addEventListener('dblclick', () => {
        clearTimeout(clickTimer);
        startRename(row, name, layer);
      });

      const op = document.createElement('input');
      op.type = 'range';
      op.min = '0';
      op.max = '100';
      op.value = String(Math.round(layer.opacity * 100));
      op.className = 'layer-op';
      op.title = 'Opacity';
      op.addEventListener('input', () => {
        layer.opacity = Number(op.value) / 100;
        composite();
      });
      op.addEventListener('change', saveDraft);

      row.appendChild(vis);
      row.appendChild(name);
      row.appendChild(op);

      // Reorder controls: up = toward the front of the stack, down = toward the back.
      const up = document.createElement('button');
      up.type = 'button';
      up.className = 'layer-btn';
      up.textContent = '▲';
      up.title = 'Move layer up (toward front)';
      up.disabled = idx === layers.length - 1;
      up.addEventListener('click', () => moveLayer(layer.id, 1));

      const down = document.createElement('button');
      down.type = 'button';
      down.className = 'layer-btn';
      down.textContent = '▼';
      down.title = 'Move layer down (toward back)';
      down.disabled = idx === 0;
      down.addEventListener('click', () => moveLayer(layer.id, -1));

      row.appendChild(up);
      row.appendChild(down);

      if (layer.minor === 0) {
        const add = document.createElement('button');
        add.type = 'button';
        add.className = 'layer-btn';
        add.textContent = '+';
        add.title = `Add a ${layer.name} sub-layer`;
        add.addEventListener('click', () => addChild(layer.major));
        row.appendChild(add);
      } else {
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'layer-btn';
        del.textContent = '×';
        del.title = 'Delete sub-layer';
        del.addEventListener('click', () => deleteLayer(layer.id));
        row.appendChild(del);
      }

      layerListEl.appendChild(row);
    }
  }

  // Rename affordance (Dan-direct 070226): double-click a layer name, type,
  // Enter commits (empty resets to the canonical 0/1/2-model name), Escape
  // cancels. Only the display label changes; the layer identity is untouched.
  function startRename(row, nameBtn, layer) {
    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'layer-rename';
    input.maxLength = 40;
    input.value = layer.label || '';
    input.placeholder = layer.name;
    row.replaceChild(input, nameBtn);
    input.focus();
    input.select();
    let doneOnce = false;
    const finish = (commit) => {
      if (doneOnce) return;
      doneOnce = true;
      if (commit) {
        const was = displayName(layer);
        layer.label = input.value.trim();
        saveDraft();
        setStatus(`RENAMED ${was} -> ${displayName(layer)}`);
      }
      renderLayers();
    };
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); finish(true); }
      if (e.key === 'Escape') { e.preventDefault(); finish(false); }
    });
    input.addEventListener('blur', () => finish(true));
  }

  // ---- Drawing (onto the active layer) -----------------------------------
  function selectedDimensions() {
    const dimensions = dimensionInputs.filter((input) => input.checked).map((input) => input.value);
    return dimensions.length ? dimensions : ['2D'];
  }

  function buildCoordinate() {
    return {
      trace: captionInput.value.trim() || 'DRW drawing',
      sourceSurface: 'drw',
      dimensionTags: selectedDimensions(),
      confidence: confidenceInput ? confidenceInput.value : 'observed',
      sourceContext: sourceInput ? sourceInput.value.trim() : 'rspdan.com/drw',
      resolver: resolverInput ? resolverInput.value.trim() : '',
      activeInk: ink,
      activeTool: tool,
      lineWidth: Number(sizeInput.value),
    };
  }

  function pointerPos(event) {
    const rect = view.getBoundingClientRect();
    return {
      x: (event.clientX - rect.left) * (W / rect.width),
      y: (event.clientY - rect.top) * (H / rect.height),
    };
  }

  function begin(event) {
    const layer = activeLayer();
    if (!layer || !layer.visible) {
      setStatus(layer ? 'ACTIVE LAYER HIDDEN' : 'NO ACTIVE LAYER');
      return;
    }
    event.preventDefault();
    if (tool === 'text') {
      const tp = pointerPos(event);
      openTextEditor(tp.x, tp.y);
      return;
    }
    snapshotBefore();
    view.setPointerCapture(event.pointerId);
    drawing = true;
    const p = pointerPos(event);
    lastX = p.x;
    lastY = p.y;
  }

  // TEXT tool · FIXED 070226 (Dan-direct "Fix the text tool"). What was
  // broken: the old tool fired a blocking window.prompt() from inside the
  // pointerdown handler. The text was invisible until committed (no preview,
  // no position feedback), single-line only in practice (a prompt box cannot
  // enter the newlines the code then split on), it froze the whole page while
  // open, and it was unusable on touch. Now an inline on-canvas editor: click
  // opens a type-box AT the click point, in the current ink and size (Make It
  // Visible: what you type previews where it lands). Enter places it on the
  // ACTIVE layer, Shift+Enter adds a line, Escape cancels, clicking away
  // places it. Same 8-line/80-char bounds and per-layer undo as before.
  let textAt = null; // canvas-space anchor while the editor is open

  function canvasFontSize() {
    return Math.max(14, Math.min(96, Number(sizeInput.value) * 5));
  }

  function openTextEditor(x, y) {
    const layer = activeLayer();
    if (!layer || !layer.visible) {
      setStatus(layer ? 'ACTIVE LAYER HIDDEN' : 'NO ACTIVE LAYER');
      return;
    }
    textAt = { x, y };
    const rect = view.getBoundingClientRect();
    const scale = rect.width / W;
    const fontPx = canvasFontSize() * scale;
    textEditor.hidden = false;
    textEditor.value = '';
    textEditor.style.left = `${view.offsetLeft + x * scale}px`;
    textEditor.style.top = `${view.offsetTop + y * scale}px`;
    textEditor.style.font = `${fontPx}px "JetBrains Mono", Consolas, monospace`;
    textEditor.style.color = ink;
    textEditor.style.height = `${fontPx * 1.35}px`;
    textEditor.focus();
    setStatus('TEXT: TYPE · ENTER PLACES · SHIFT+ENTER NEW LINE · ESC CANCELS');
  }

  function closeTextEditor() {
    textEditor.hidden = true;
    textEditor.value = '';
    textAt = null;
  }

  function commitText() {
    const layer = activeLayer();
    const text = textEditor.value.replace(/\s+$/, '');
    if (!textAt || !layer || !layer.visible || !text) {
      closeTextEditor();
      setStatus('TEXT CANCELLED');
      return;
    }
    snapshotBefore();
    const lines = text.split(/\r?\n/).slice(0, 8);
    const fontSize = canvasFontSize();
    const anchor = textAt;
    const lctx = layer.ctx;
    lctx.save();
    lctx.fillStyle = ink;
    lctx.font = `${fontSize}px "JetBrains Mono", Consolas, monospace`;
    lctx.textBaseline = 'top';
    lines.forEach((line, index) => lctx.fillText(line.slice(0, 80), anchor.x, anchor.y + index * fontSize * 1.15));
    lctx.restore();
    closeTextEditor();
    composite();
    saveDraft();
    setStatus('TEXT PLACED');
  }

  textEditor.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); commitText(); }
    if (e.key === 'Escape') { e.preventDefault(); closeTextEditor(); setStatus('TEXT CANCELLED'); }
  });
  textEditor.addEventListener('blur', () => { if (!textEditor.hidden) commitText(); });
  textEditor.addEventListener('input', () => {
    // Auto-grow with the typed lines so the preview stays visible.
    const rect = view.getBoundingClientRect();
    const fontPx = canvasFontSize() * (rect.width / W);
    const lineCount = textEditor.value.split(/\r?\n/).length;
    textEditor.style.height = `${fontPx * 1.35 * Math.max(1, lineCount)}px`;
  });

  function move(event) {
    if (!drawing) return;
    event.preventDefault();
    const layer = activeLayer();
    if (!layer) return;
    const lctx = layer.ctx;
    const p = pointerPos(event);
    lctx.save();
    lctx.globalCompositeOperation = tool === 'erase' ? 'destination-out' : 'source-over';
    lctx.strokeStyle = ink;
    lctx.lineWidth = Number(sizeInput.value);
    lctx.lineCap = 'round';
    lctx.lineJoin = 'round';
    lctx.beginPath();
    lctx.moveTo(lastX, lastY);
    lctx.lineTo(p.x, p.y);
    lctx.stroke();
    lctx.restore();
    lastX = p.x;
    lastY = p.y;
    composite();
  }

  function end(event) {
    if (!drawing) return;
    drawing = false;
    if (event && event.pointerId !== undefined) view.releasePointerCapture(event.pointerId);
    setStatus('DRAWING MODIFIED');
    saveDraft();
  }

  // ---- Autosave draft (nothing gets lost on a crash / closed tab) ---------
  let draftTimer = null;
  function saveDraft() {
    if (draftTimer) clearTimeout(draftTimer);
    draftTimer = setTimeout(() => {
      try {
        const scene = serializeScene();
        localStorage.setItem(DRAFT_KEY, JSON.stringify(scene));
      } catch (err) {
        // Draft autosave is best-effort; never let it break drawing.
      }
    }, 400);
  }

  function serializeScene() {
    return {
      version: 1,
      width: W,
      height: H,
      activeId,
      layers: layers.map((l) => ({
        id: l.id,
        major: l.major,
        minor: l.minor,
        name: l.name,
        label: l.label || '',
        opacity: l.opacity,
        visible: l.visible,
        png: l.canvas.toDataURL('image/png'),
      })),
    };
  }

  function restoreScene(scene, done) {
    if (!scene || !Array.isArray(scene.layers) || !scene.layers.length) {
      defaultLayers();
      done();
      return;
    }
    const rebuilt = [];
    let pending = scene.layers.length;
    scene.layers.forEach((data) => {
      const layer = makeLayer(data.major, data.minor, typeof data.opacity === 'number' ? data.opacity : 1, data.visible !== false, data.label);
      rebuilt.push(layer);
      const img = new Image();
      img.onload = () => {
        layer.ctx.drawImage(img, 0, 0);
        if (--pending === 0) finish();
      };
      img.onerror = () => { if (--pending === 0) finish(); };
      img.src = data.png;
    });
    function finish() {
      layers = rebuilt; // keep the saved array order (the operator's order persists)
      activeId = scene.activeId && layers.some((l) => l.id === scene.activeId) ? scene.activeId : '2';
      done();
    }
  }

  // ---- Save + relay (scene + flat composite) -----------------------------
  function renderList(items) {
    if (!items.length) {
      drawList.innerHTML = '<div class="draw-empty">NO SAVES YET</div>';
      return;
    }
    drawList.innerHTML = items.map((item) => {
      const date = new Date(item.createdAt || item.ts).toLocaleString();
      const caption = escapeHtml(item.caption || '');
      const dimensions = Array.isArray(item.dimensionTags) ? escapeHtml(item.dimensionTags.join('/')) : '';
      const confidence = item.confidence ? escapeHtml(item.confidence.toString().toUpperCase()) : '';
      const imageUrl = safeHttpUrl(item.url);
      const packetUrl = safeHttpUrl(item.packetUrl);
      const packet = packetUrl ? `<a class="packet-link" href="${packetUrl}" target="_blank" rel="noreferrer">PACKET</a>` : '';
      if (!imageUrl) return '';
      return `
        <article class="draw-item">
          <a href="${imageUrl}" target="_blank" rel="noreferrer"><img src="${imageUrl}" alt="${caption || 'Saved drawing'}" loading="lazy" /></a>
          <div>
            <strong>${caption || 'UNTITLED'}</strong>
            <span>${date}</span>
            ${dimensions || confidence ? `<span>${dimensions}${dimensions && confidence ? ' / ' : ''}${confidence}</span>` : ''}
            ${packet}
          </div>
        </article>
      `;
    }).join('');
  }

  async function loadDrawings() {
    try {
      const res = await fetch('/api/drw?limit=18');
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || `HTTP ${res.status}`);
      renderList(data.drawings || []);
      setStatus('READY');
    } catch (err) {
      drawList.innerHTML = '<div class="draw-empty">INDEX OFFLINE</div>';
      setStatus(`READ ERROR: ${err.message}`);
    }
  }

  async function saveDrawing() {
    saveBtn.disabled = true;
    saveBtn.textContent = 'SAVING...';
    setStatus('SAVING SCENE + PNG + RELAY');
    try {
      composite();
      const scene = serializeScene();
      const res = await fetch('/api/drw', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          image: view.toDataURL('image/png'),
          scene,
          caption: captionInput.value,
          coordinate: buildCoordinate(),
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || `HTTP ${res.status}`);
      captionInput.value = '';
      await loadDrawings();
      setStatus(`SAVED ${data.drawing.id}`);
    } catch (err) {
      setStatus(`SAVE ERROR: ${err.message}`);
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'SAVE + RELAY';
    }
  }

  // ---- Wiring ------------------------------------------------------------
  toolButtons.forEach((button) => {
    button.addEventListener('click', () => {
      tool = button.dataset.tool;
      toolButtons.forEach((b) => b.classList.toggle('is-active', b === button));
      setStatus(`${tool.toUpperCase()} SELECTED`);
    });
  });

  swatches.forEach((button) => {
    button.addEventListener('click', () => {
      ink = button.dataset.color;
      swatches.forEach((s) => s.classList.toggle('is-active', s === button));
      setStatus(`INK ${button.title || ''}`.trim());
    });
  });

  clearBtn.addEventListener('click', () => {
    const layer = activeLayer();
    if (!layer) return;
    snapshotBefore();
    layer.ctx.clearRect(0, 0, W, H);
    if (layer.major === 0 && layer.minor === 0) {
      layer.ctx.fillStyle = '#ffffff';
      layer.ctx.fillRect(0, 0, W, H);
    }
    composite();
    saveDraft();
    setStatus(`CLEARED ${displayName(layer)}`);
  });

  undoBtn.addEventListener('click', undo);
  redoBtn.addEventListener('click', redo);
  saveBtn.addEventListener('click', saveDrawing);
  view.addEventListener('pointerdown', begin);
  view.addEventListener('pointermove', move);
  view.addEventListener('pointerup', end);
  view.addEventListener('pointercancel', end);

  // ---- L&L (Launch & Load) handlers · the drawing-side half ---------------
  // Dan-direct 070226: L&L "Should function as a general 'open anything and
  // it works' + nothing gets lost + Make It Visible." The console script owns
  // the L&L entry + dispatch; these are the handlers that land inside the
  // drawing model. Each is a working increment; the registry extends.

  // Open an image: it lands on a NEW Color child layer named after the file
  // (Make It Visible: the layer is active and announced; nothing existing is
  // painted over).
  function openImageFile(file) {
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        const label = file.name.replace(/\.[^.]+$/, '').slice(0, 40);
        const layer = addChild(1, label);
        // Fit-contain, centered: the whole image is visible, aspect kept.
        const scale = Math.min(W / img.width, H / img.height, 1);
        const dw = img.width * scale;
        const dh = img.height * scale;
        layer.ctx.drawImage(img, (W - dw) / 2, (H - dh) / 2, dw, dh);
        composite();
        saveDraft();
        setStatus(`L&L: IMAGE ${file.name} -> LAYER ${displayName(layer)} (${layer.id})`);
      };
      img.onerror = () => setStatus(`L&L: COULD NOT DECODE IMAGE ${file.name}`);
      img.src = reader.result;
    };
    reader.onerror = () => setStatus(`L&L: COULD NOT READ ${file.name}`);
    reader.readAsDataURL(file);
  }

  // Open a DRW draft (.drw.json, the file EXPORT DRAFT writes). NOTHING GETS
  // LOST: the current working scene is backed up to a timestamped key before
  // the draft replaces it (last 3 backups kept).
  function backupCurrentScene() {
    try {
      localStorage.setItem(BACKUP_PREFIX + Date.now(), JSON.stringify(serializeScene()));
      const keys = Object.keys(localStorage).filter((k) => k.startsWith(BACKUP_PREFIX)).sort();
      while (keys.length > 3) localStorage.removeItem(keys.shift());
      return true;
    } catch (err) {
      return false; // quota: the operator is told below, not silently dropped
    }
  }

  function openDraftFile(file) {
    const reader = new FileReader();
    reader.onload = () => {
      let scene = null;
      try { scene = JSON.parse(reader.result); } catch (err) { scene = null; }
      if (!scene || !Array.isArray(scene.layers) || !scene.layers.length) {
        setStatus(`L&L: ${file.name} IS NOT A DRW DRAFT (expected the .drw.json EXPORT DRAFT writes)`);
        return;
      }
      const backed = backupCurrentScene();
      restoreScene(scene, () => {
        renderLayers();
        composite();
        saveDraft();
        setStatus(`L&L: DRAFT ${file.name} LOADED${backed ? ' · PREVIOUS WORK BACKED UP' : ' · WARNING: BACKUP FAILED (storage full)'}`);
      });
    };
    reader.onerror = () => setStatus(`L&L: COULD NOT READ ${file.name}`);
    reader.readAsText(file);
  }

  // EXPORT DRAFT: writes the file L&L opens back (the round-trip that makes
  // "open anything" include your own work).
  function exportDraft() {
    const scene = serializeScene();
    const stamp = new Date().toISOString().replace(/[-:]/g, '').replace('T', '_').slice(0, 13);
    const blob = new Blob([JSON.stringify(scene)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `DRW_${stamp}.drw.json`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(a.href), 5000);
    setStatus(`EXPORTED DRAFT ${a.download} (L&L opens it back)`);
  }

  exportDraftBtn.addEventListener('click', exportDraft);

  // The console script (game mode + the L&L entry) dispatches into these.
  window.DRW = { openImageFile, openDraftFile, exportDraft, setStatus };

  // Boot: restore the autosaved working draft if present, else default layers.
  let stored = null;
  try { stored = JSON.parse(localStorage.getItem(DRAFT_KEY) || 'null'); } catch (err) { stored = null; }
  restoreScene(stored, () => {
    renderLayers();
    composite();
    setStatus(stored ? 'RESTORED WORKING DRAFT' : 'READY');
  });
  loadDrawings();
</script>

<script>
  // ---- NEST CONSOLE (the ConsOlo) · game mode + the L&L entry -------------
  // The console is DRW by default but can LOAD GAMES and play them
  // (Dan-direct 070226). L&L (Launch & Load, Dan-direct 070226) generalizes
  // the LOAD GAME seed: one entry opens anything the registry knows (game
  // cartridge here; images + DRW drafts dispatch into the drawing script's
  // window.DRW handlers). The emulator is EmulatorJS (its bundled GBA core,
  // mGBA-family), SELF-HOSTED at /vendor/emulatorjs/data/ (vendored 4.2.3,
  // see public/vendor/emulatorjs/README.md) so play does not depend on a
  // third-party CDN at runtime; the CDN is only the automatic fallback if
  // the vendored copy fails to load. We do not hand-write an emulator and
  // no ROM ships in this repo. Dan loads his own cartridge from disk
  // (Pokemon LeafGreen is the first game); an optional .sav battery save
  // (MyBoy/mGBA raw format) loads with it.
  const EJS_LOCAL = '/vendor/emulatorjs/data/';
  const EJS_CDN = 'https://cdn.emulatorjs.org/stable/data/';

  const gameFrame = document.getElementById('game-frame');
  const videoFrame = document.getElementById('video-frame');
  const videoPlayer = document.getElementById('video-player');
  const videoName = document.getElementById('video-name');
  const lnlBtn = document.getElementById('lnl-btn');
  const ejectGameBtn = document.getElementById('eject-game-btn');
  const lnlInput = document.getElementById('lnl-input');
  const savInput = document.getElementById('sav-input');
  const savBtn = document.getElementById('sav-btn');
  const powerBtn = document.getElementById('power-btn');
  const cartridgeName = document.getElementById('cartridge-name');
  const consoleStatusLine = document.getElementById('status-line');
  const drwWindow = document.querySelector('.drw-window');

  let romFile = null;
  let savBytes = null;
  let consolePowered = false;

  function consoleStatus(text) {
    if (consoleStatusLine) consoleStatusLine.textContent = text;
  }

  // ---- L&L (Launch & Load) dispatch ---------------------------------------
  // "Open anything and it works" (Dan-direct 070226). One entry; the registry
  // routes by type. Opens NOW: a game cartridge, an image (new Color child
  // layer), a DRW draft (.drw.json, with the current work backed up first).
  // Extending = add a matcher + handler here; unknown types get an HONEST
  // status line naming what opens today, never a silent no-op.
  const GAME_EXTS = ['gba', 'gb', 'gbc', 'zip'];
  const IMAGE_EXTS = ['png', 'jpg', 'jpeg', 'gif', 'webp', 'bmp', 'svg'];
  const VIDEO_EXTS = ['mp4', 'webm', 'mov', 'm4v', 'ogv'];

  lnlBtn.addEventListener('click', () => {
    if (consolePowered) {
      // EmulatorJS has no clean teardown; opening something else mid-game is
      // a reload. The DRW working draft is autosaved to localStorage, nothing
      // is lost.
      window.location.reload();
      return;
    }
    lnlInput.click();
  });

  lnlInput.addEventListener('change', () => {
    const file = lnlInput.files && lnlInput.files[0];
    lnlInput.value = '';
    if (!file) return;
    openAnything(file);
  });

  function openAnything(file) {
    const ext = (file.name.toLowerCase().split('.').pop() || '');
    // A playing video yields to whatever opens next (no reload needed; the
    // DRW draft never left). Closing first keeps every path's UI sane.
    if (videoLoaded && !VIDEO_EXTS.includes(ext) && !(file.type || '').startsWith('video/')) closeVideo(false);
    if (GAME_EXTS.includes(ext)) { openCartridge(file); return; }
    if (IMAGE_EXTS.includes(ext) || (file.type || '').startsWith('image/')) { window.DRW.openImageFile(file); return; }
    if (VIDEO_EXTS.includes(ext) || (file.type || '').startsWith('video/')) { openVideoFile(file); return; }
    if (ext === 'json') { window.DRW.openDraftFile(file); return; }
    consoleStatus(`L&L: .${ext || '?'} NOT WIRED YET · opens now: game .gba/.gb/.gbc/.zip · image · video .mp4/.webm/.mov · DRW draft .drw.json · the registry extends`);
  }

  // ---- Video (registry extension 070326) ----------------------------------
  // Same mechanic as the cartridge: the console screen shows the media, DRW
  // markup/state stays intact underneath. Unlike a game there is no emulator
  // teardown problem, so EJECT restores DRW in place (no reload). The file
  // plays from a local object URL; nothing is uploaded and nothing is
  // persisted (persistence is a deliberate follow-up, not wired this pass).
  let videoLoaded = false;
  let videoUrl = null;

  function openVideoFile(file) {
    if (consolePowered || romFile) { consoleStatus('CARTRIDGE OWNS THE SCREEN · EJECT FIRST'); return; }
    if (videoUrl) URL.revokeObjectURL(videoUrl);
    videoUrl = URL.createObjectURL(file);
    videoPlayer.src = videoUrl;
    videoName.textContent = file.name;
    videoLoaded = true;
    drwWindow.classList.add('is-video');
    videoFrame.hidden = false;
    ejectGameBtn.hidden = false;
    consoleStatus(`L&L: VIDEO ${file.name} ON THE CONSOLE SCREEN · EJECT RETURNS TO DRW`);
  }

  function closeVideo(announce) {
    if (!videoLoaded) return;
    try { videoPlayer.pause(); } catch (err) { /* not playing */ }
    videoPlayer.removeAttribute('src');
    videoPlayer.load();
    if (videoUrl) { URL.revokeObjectURL(videoUrl); videoUrl = null; }
    videoLoaded = false;
    videoFrame.hidden = true;
    drwWindow.classList.remove('is-video');
    ejectGameBtn.hidden = true;
    if (announce) consoleStatus('VIDEO EJECTED · BACK TO DRW');
  }

  videoPlayer.addEventListener('error', () => {
    if (!videoLoaded) return;
    consoleStatus(`L&L: THIS BROWSER COULD NOT DECODE ${videoName.textContent} (codec) · EJECT RETURNS TO DRW`);
  });

  function openCartridge(file) {
    romFile = file;
    cartridgeName.textContent = file.name;
    drwWindow.classList.add('is-game');
    gameFrame.hidden = false;
    ejectGameBtn.hidden = false;
    consoleStatus(`CARTRIDGE LOADED: ${file.name} · INSERT .SAV (OPTIONAL) THEN POWER ON`);
  }

  savBtn.addEventListener('click', () => savInput.click());

  savInput.addEventListener('change', async () => {
    const file = savInput.files && savInput.files[0];
    if (!file) return;
    savBytes = new Uint8Array(await file.arrayBuffer());
    savBtn.textContent = `SAV: ${file.name}`;
    consoleStatus(`BATTERY SAVE INSERTED: ${file.name} (${savBytes.length} bytes)`);
  });

  ejectGameBtn.addEventListener('click', () => {
    // Video mode restores DRW in place (no emulator teardown problem).
    if (videoLoaded && !consolePowered && !romFile) { closeVideo(true); return; }
    // Game mode: reload returns the console to its DRW default screen.
    window.location.reload();
  });

  powerBtn.addEventListener('click', () => {
    if (!romFile || consolePowered) return;
    consolePowered = true;
    powerBtn.disabled = true;
    savBtn.disabled = true;
    consoleStatus('BOOTING EMULATOR CORE...');

    const ext = romFile.name.toLowerCase().split('.').pop();
    window.EJS_player = '#ejs-mount';
    window.EJS_core = ext === 'gb' || ext === 'gbc' ? 'gb' : 'gba';
    window.EJS_gameUrl = URL.createObjectURL(romFile);
    window.EJS_gameName = romFile.name.replace(/\.(gba|gb|gbc|zip)$/i, '');
    window.EJS_pathtodata = EJS_LOCAL;
    window.EJS_startOnLoaded = true;
    window.EJS_backgroundColor = '#111111';
    // Ensure the battery-save round-trip buttons are present in the
    // emulator's control bar (Export Save File / Import Save File).
    window.EJS_Buttons = { saveSavFiles: true, loadSavFiles: true };
    window.EJS_onGameStart = () => {
      consoleStatus(`PLAYING: ${romFile.name}`);
      if (savBytes) injectBatterySave();
    };

    // Boot from the vendored runtime; if it is missing (e.g. a stripped
    // deploy), fall back to the upstream CDN once.
    const bootLoader = (pathtodata, onFail) => {
      window.EJS_pathtodata = pathtodata;
      const loader = document.createElement('script');
      loader.src = pathtodata + 'loader.js';
      loader.onerror = onFail;
      document.body.appendChild(loader);
    };
    bootLoader(EJS_LOCAL, () => {
      consoleStatus('VENDORED EMULATOR MISSING · TRYING CDN FALLBACK...');
      bootLoader(EJS_CDN, () => {
        consoleStatus('EMULATOR CORE FAILED TO LOAD (vendored copy and CDN both unreachable)');
      });
    });
  });

  function injectBatterySave() {
    // Write the inserted .sav where the core expects the battery save, then
    // ask the core to load it (the same path the emulator's own IMPORT SAVE
    // button uses). If the internal API shape differs, the built-in IMPORT
    // SAVE button in the emulator menu is the fallback.
    try {
      const gm = window.EJS_emulator.gameManager;
      const path = gm.getSaveFilePath();
      const dir = path.substring(0, path.lastIndexOf('/'));
      let walk = '';
      for (const part of dir.split('/')) {
        if (!part) continue;
        walk += '/' + part;
        try { gm.FS.mkdir(walk); } catch (e) { /* dir exists */ }
      }
      try { gm.FS.unlink(path); } catch (e) { /* no prior save */ }
      gm.FS.writeFile(path, savBytes);
      gm.loadSaveFiles();
      consoleStatus(`PLAYING: ${romFile.name} · BATTERY SAVE LOADED`);
    } catch (err) {
      consoleStatus('SAV AUTO-LOAD FAILED · use IMPORT SAVE in the emulator menu');
    }
  }
</script>

<style is:global>
  /* is:global (070226): the layers panel rows (.layer-row, .layer-name,
     .layer-rename, .layer-btn ...) and the RECENT list (.draw-item) are
     created by the page script at runtime; Astro's default scoped styles
     never match JS-created nodes, so those elements rendered UNSTYLED under
     the previous skin too (verified via computed-style in Playwright). The
     selectors are all /drw-local (.drw-*, .layer-*, .swatch, #ids), and page
     styles ship only with this page. */
  /* ==== VISdev.01 LITE BRITE register skin (El VIS kit,
     VISdev-Kit-LiteBrite.html: "real-artificial · 1996 chrome, 2026 engine").
     Black pegboard #08080a with the peg-hole texture, VT323 CRT terminal type
     + Silkscreen pixel labels, OLO #01FFCD as THE glow (active tool, focus,
     live signals, THE CONSOLO badge). CRT scanline + vignette overlays ride
     the window, pointer-events:none. The skin WRAPS the DRW.EXE workbench
     chrome; the .EXE window/menu/bevel idiom stays (the 1996 chrome), the
     Usic colors + non-colors stay the drawing palette, rendered as glowing
     pegs per the kit's .dot idiom. Token values byte-exact from the kit
     :root. ==== */
  .drw-shell {
    width: min(1280px, calc(100vw - 2rem));
    margin: 1rem auto 4rem;
    /* LITE BRITE tokens (kit :root values). */
    --lb-bg: #08080a;
    --lb-hole: rgba(255, 255, 255, 0.045);
    --lb-txt: #dce1e4;
    --lb-dim: #7e858a;
    --olo: #01FFCD;
    --lb-line: rgba(255, 255, 255, 0.08);
    --lb-panel: #101014;
    --lb-well: #0b0b0e;
    --lb-bevel-lt: rgba(255, 255, 255, 0.22);
    --lb-bevel-dk: #000000;
    --font-crt: 'VT323', monospace;
    --font-pix: 'Silkscreen', monospace;
  }
  .drw-window {
    /* The pegboard: near-black field + the kit's peg-hole texture. relative
       anchors the CRT overlays. */
    position: relative;
    background-color: var(--lb-bg);
